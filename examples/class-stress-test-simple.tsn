import { } from  'std:sf'

/**
 * SIMPLIFIED CLASS STRESS TEST
 * Tests core functionality step by step
 */

// TEST 1: Basic class with 'this' type
print("TEST 1: Basic 'this' type")

class Builder {
    protected value: int

    constructor() {
        this.value = 0
    }

    setValue(v: int): this {
        this.value = v
        return this
    }

    getValue(): int {
        return this.value
    }
}

const b1 = new Builder()
b1.setValue(42)
print("Value: " + b1.getValue().toString())
print("TEST 1 passed")
print("")

// TEST 2: Inheritance with 'this' type
print("TEST 2: Inheritance with 'this' type")

class AdvancedBuilder extends Builder {
    private multiplier: int

    constructor() {
        super()
        this.multiplier = 1
    }

    setMultiplier(m: int): this {
        this.multiplier = m
        return this
    }

    compute(): int {
        return this.value * this.multiplier
    }
}

const b2 = new AdvancedBuilder()
b2.setValue(10).setMultiplier(3)
print("Computed: " + b2.compute().toString())
print("TEST 2 passed")
print("")

// TEST 3: Deep inheritance chain
print("TEST 3: Deep inheritance")

class Animal {
    protected name: str

    constructor(n: str) {
        this.name = n
    }

    makeSound(): str {
        return "Some sound"
    }

    getName(): str {
        return this.name
    }
}

class Dog extends Animal {
    constructor(n: str) {
        super(n)
    }

    makeSound(): str {
        return "Woof!"
    }
}

class Cat extends Animal {
    constructor(n: str) {
        super(n)
    }

    makeSound(): str {
        return "Meow!"
    }
}

const dog = new Dog("Rex")
const cat = new Cat("Whiskers")

print("Dog: " + dog.getName() + " says " + dog.makeSound())
print("Cat: " + cat.getName() + " says " + cat.makeSound())
print("TEST 3 passed")
print("")

// TEST 4: Static methods
print("TEST 4: Static methods")

class MathUtils {
    static PI: int

    static double(x: int): int {
        return x * 2
    }
}

MathUtils.PI = 3
print("PI = " + MathUtils.PI.toString())
print("Double 5 = " + MathUtils.double(5).toString())
print("TEST 4 passed")
print("")

// TEST 5: Method chaining
print("TEST 5: Method chaining")

class Calculator {
    private result: int

    constructor() {
        this.result = 0
    }

    add(x: int): this {
        this.result = this.result + x
        return this
    }

    multiply(x: int): this {
        this.result = this.result * x
        return this
    }

    getResult(): int {
        return this.result
    }
}

const calc = new Calculator()
const calcResult = calc.add(10).multiply(2).add(5).getResult()
print("Calculation result: " + calcResult.toString())
print("TEST 5 passed")
print("")

print("=== ALL BASIC TESTS PASSED ===")
