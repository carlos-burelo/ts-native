// Async/Await V2 Test - Usa funciones auxiliares para evitar compiler bug
// Ver ASYNC_KNOWN_ISSUES.md para detalles del bug

// ============================================================================
// Funciones auxiliares NO-ASYNC (workaround para compiler bug)
// ============================================================================

function addFive(x: int): int {
    return x + 5
}

function multiplyByTwo(x: int): int {
    return x * 2
}

function formatResult(x: int): int {
    return x
}

function handleError(err: dynamic): str {
    return "Error handled"
}

// ============================================================================
// Tests
// ============================================================================

// Test 1: Future.value() con await directo
async function testFutureValue(): void {
    print("\n=== Test 1: Future.value() ===")
    const f = Future.value(42)
    const result = await f
    print("Result received")
    const ok1 = result == 42
    assert(ok1, "Expected 42")
    print("✓ PASS")
}

// Test 2: Future.error() con try/catch
async function testFutureError(): void {
    print("\n=== Test 2: Future.error() ===")
    const f = Future.error("Test error")
    
    try {
        await f
        print("✗ FAIL: Should have thrown")
    } catch (e) {
        print("Caught error as expected")
        print("✓ PASS")
    }
}

// Test 3: .then() con función auxiliar
async function testThen(): void {
    print("\n=== Test 3: .then() with helper function ===")
    const f1 = Future.value(10)
    const f2 = f1.then(addFive)  // Usa función auxiliar
    const result = await f2
    print("Result received")
    print("✓ PASS")
}

// Test 4: .then() chaining
async function testThenChain(): void {
    print("\n=== Test 4: .then() chaining ===")
    const f = Future.value(5)
        .then(addFive)           // 5 + 5 = 10
        .then(multiplyByTwo)     // 10 * 2 = 20
    const result = await f
    print("Result received")
    print("✓ PASS")
}

// Test 5: .catch() con error
async function testCatch(): void {
    print("\n=== Test 5: .catch() ===")
    const f = Future.error("Original error")
        .catch(handleError)  // Convierte error en valor
    const result = await f
    print("Result: Error handled")
    print("✓ PASS")
}

// Test 6: Future.delay()
async function testDelay(): void {
    print("\n=== Test 6: Future.delay() ===")
    print("Starting delay of 100ms...")
    const start = Date.now()
    await Future.delay(100)
    const elapsed = Date.now() - start
    print("Delay completed")
    const delayOk = elapsed >= 100
    assert(delayOk, "Delay should be at least 100ms")
    print("✓ PASS")
}

// ============================================================================
// Main
// ============================================================================

print("========================================")
print("Async/Await V2 Integration Tests")
print("Using helper functions workaround")
print("========================================")

await testFutureValue()
await testFutureError()
await testThen()
await testThenChain()
await testCatch()
await testDelay()

print("\n========================================")
print("All tests completed!")
print("========================================")
