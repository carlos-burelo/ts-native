// services/auth.tsn — Authentication helpers

import { User, Role, createGuestUser } from '../models/user.tsn';
import { capitalize }                  from '../utils/strings.tsn';

export const AUTH_VERSION: int = 1;

export enum AuthStatus {
    Ok          = 0,
    Unauthorized = 1,
    Forbidden   = 2,
    NotFound    = 3,
}

export class AuthResult {
    status:  AuthStatus;
    message: str;
    user:    User | null;

    constructor(status: AuthStatus, message: str, user: User | null) {
        this.status  = status;
        this.message = message;
        this.user    = user;
    }

    isOk(): bool {
        return this.status === AuthStatus.Ok;
    }

    toString(): str {
        return "AuthResult(" + this.status.toString() + ", " + this.message + ")";
    }
}

export function authorize(user: User, requiredRole: Role): AuthResult {
    if (user.role < requiredRole) {
        return new AuthResult(
            AuthStatus.Forbidden,
            capitalize(user.username) + " lacks required role",
            user
        );
    }
    return new AuthResult(AuthStatus.Ok, "authorized", user);
}

export function authenticateGuest(name: str): AuthResult {
    const guest: User = createGuestUser(name);
    return new AuthResult(AuthStatus.Ok, "guest session started", guest);
}
