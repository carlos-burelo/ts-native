// models/user.tsn — User domain model

import { clamp, MAX_SAFE_INT } from '../utils/math.tsn';
import { capitalize, slugify }  from '../utils/strings.tsn';

export const USER_VERSION: int = 2;

export enum Role {
    Guest   = 0,
    Member  = 1,
    Admin   = 2,
    Owner   = 3,
}

export class User {
    id:       int;
    username: str;
    email:    str;
    role:     Role;
    age:      int;

    constructor(id: int, username: str, email: str, role: Role, age: int) {
        this.id       = clamp(id, 1, MAX_SAFE_INT);
        this.username = capitalize(username);
        this.email    = email.toLowerCase();
        this.role     = role;
        this.age      = clamp(age, 0, 150);
    }

    slug(): str {
        return slugify(this.username);
    }

    isAdmin(): bool {
        return this.role === Role.Admin || this.role === Role.Owner;
    }

    toString(): str {
        return "User(" + this.id.toString() + ", " + this.username + ", " + this.email + ")";
    }
}

export function createGuestUser(username: str): User {
    return new User(0, username, username + "@guest.local", Role.Guest, 0);
}
