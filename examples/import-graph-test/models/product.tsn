// models/product.tsn — Product domain model

import { mul, clamp }                  from '../utils/math.tsn';
import { capitalize, padStart, trim }  from '../utils/strings.tsn';

export const PRODUCT_VERSION: int = 1;
export const MAX_STOCK: int        = 999999;

export enum Category {
    Electronics = 0,
    Clothing    = 1,
    Food        = 2,
    Books       = 3,
    Other       = 4,
}

export class Product {
    id:       int;
    name:     str;
    price:    float;
    stock:    int;
    category: Category;

    constructor(id: int, name: str, price: float, stock: int, category: Category) {
        this.id       = id;
        this.name     = capitalize(trim(name));
        this.price    = price;
        this.stock    = clamp(stock, 0, MAX_STOCK);
        this.category = category;
    }

    totalValue(): float {
        return this.price * this.stock;
    }

    sku(): str {
        return padStart(this.id.toString(), 8, "0");
    }

    isInStock(): bool {
        return this.stock > 0;
    }

    discounted(percent: int): float {
        const factor: int = clamp(percent, 0, 100);
        return this.price * (1.0 - factor / 100.0);
    }

    toString(): str {
        return "Product(" + this.sku() + ", " + this.name + ", $" + this.price.toString() + ")";
    }
}

export function bulkTotal(price: float, qty: int, discountPct: int): float {
    const factor: int = clamp(discountPct, 0, 100);
    return mul(qty, 1) * price * (1.0 - factor / 100.0);
}
