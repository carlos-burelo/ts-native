// import-graph-test/main.tsn
// Entry point that ties together the entire module graph.
//
// Import graph (3 levels deep):
//
//   main.tsn
//   ├── ./utils/index.tsn       (barrel → math + strings)
//   ├── ./models/index.tsn      (barrel → user + product, as namespaces)
//   └── ./services/index.tsn    (barrel → auth + catalog, as namespaces)
//
// Run with:   tsn examples/import-graph-test/main.tsn --debug=graph --noRun
// Full graph: tsn examples/import-graph-test/main.tsn --debug=graph

import { PI, E, add, mul, clamp, lerp, Vector2 }        from './utils/math.tsn';
import { capitalize, repeat, padStart, trim, slugify }   from './utils/strings.tsn';
import * as utils                                        from './utils/index.tsn';
import { USER_VERSION, PRODUCT_VERSION }                 from './models/index.tsn';
import * as models                                       from './models/index.tsn';
import * as services                                     from './services/index.tsn';
import { console }                                       from 'std:console';

// ─── Math utilities ───────────────────────────────────────────────────────────
print("PI =", PI);
print("E  =", E);
print("add(3, 4) =", add(3, 4));
print("mul(6, 7) =", mul(6, 7));
print("clamp(150, 0, 100) =", clamp(150, 0, 100));
print("lerp(0.0, 10.0, 0.5) =", lerp(0.0, 10.0, 0.5));

const v: Vector2 = new Vector2(3.0, 4.0);
print("Vector2(3,4).length() =", v.length());

// ─── String utilities ─────────────────────────────────────────────────────────
print("capitalize('hello') =", capitalize("hello"));
print("repeat('ab', 3) =", repeat("ab", 3));
print("padStart('42', 6, '0') =", padStart("42", 6, "0"));
print("trim('  hello  ') =", trim("  hello  "));
print("slugify('Hello World') =", slugify("Hello World"));

// ─── Namespace import (utils barrel) ─────────────────────────────────────────
print("utils via namespace: PI =", utils.PI);

// ─── Model versions ───────────────────────────────────────────────────────────
print("USER_VERSION =", USER_VERSION);
print("PRODUCT_VERSION =", PRODUCT_VERSION);

// ─── User model via namespace ─────────────────────────────────────────────────
const alice: models.user.User = new models.user.User(
    1, "alice", "ALICE@EXAMPLE.COM", models.user.Role.Admin, 30
);
print(alice.toString());
print("alice.isAdmin() =", alice.isAdmin());
print("alice.slug() =", alice.slug());

// ─── Product model via namespace ──────────────────────────────────────────────
const laptop: models.product.Product = new models.product.Product(
    1001, "  gaming laptop  ", 1299.99, 42, models.product.Category.Electronics
);
print(laptop.toString());
print("laptop.sku() =", laptop.sku());
print("laptop.totalValue() =", laptop.totalValue());
print("laptop.discounted(20) =", laptop.discounted(20));

// ─── Auth service ─────────────────────────────────────────────────────────────
const authResult: services.auth.AuthResult = services.auth.authorize(
    alice, models.user.Role.Admin
);
print(authResult.toString());
print("authResult.isOk() =", authResult.isOk());

const guestResult: services.auth.AuthResult = services.auth.authenticateGuest("bob");
print(guestResult.toString());

// ─── Catalog service ─────────────────────────────────────────────────────────
const catalog: services.catalog.Catalog = new services.catalog.Catalog();
catalog.add(laptop);
catalog.add(new models.product.Product(1002, "keyboard", 89.99, 0, models.product.Category.Electronics));
catalog.add(new models.product.Product(1003, "typescript book", 39.99, 120, models.product.Category.Books));

print(catalog.report());
print("catalog.totalInventoryValue() =", catalog.totalInventoryValue());
print("bulk order (laptop × 10, 15% off) =",
    services.catalog.discountedBulkOrder(laptop, 10, 15));
