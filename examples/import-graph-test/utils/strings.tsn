// utils/strings.tsn — String utilities

export const EMPTY: str = "";
export const NEWLINE: str = "\n";

export function capitalize(s: str): str {
    if (s.length === 0) return s;
    return s[0].toUpperCase() + s.slice(1);
}

export function repeat(s: str, n: int): str {
    let result: str = "";
    let i: int = 0;
    while (i < n) {
        result = result + s;
        i = i + 1;
    }
    return result;
}

export function padStart(s: str, width: int, fill: str): str {
    const needed: int = width - s.length;
    if (needed <= 0) return s;
    return repeat(fill, needed) + s;
}

export function trim(s: str): str {
    return s.trim();
}

export function slugify(s: str): str {
    return s.toLowerCase().replace(" ", "-");
}
