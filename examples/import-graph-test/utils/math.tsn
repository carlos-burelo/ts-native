// utils/math.tsn — Numeric utilities
import { Math } from 'std:math';

export const PI: float = 3.14159265358979;
export const E: float  = 2.71828182845904;
export const MAX_SAFE_INT: int = 9007199254740991;

export function add(a: int, b: int): int {
    return a + b;
}

export function mul(a: int, b: int): int {
    return a * b;
}

export function clamp(value: int, min: int, max: int): int {
    if (value < min) return min;
    if (value > max) return max;
    return value;
}

export function lerp(a: float, b: float, t: float): float {
    return a + (b - a) * t;
}

export class Vector2 {
    x: float;
    y: float;

    constructor(x: float, y: float) {
        this.x = x;
        this.y = y;
    }

    length(): float {
        return Math.sqrt(this.x * this.x + this.y * this.y);
    }

    toString(): str {
        return "Vector2(" + this.x + ", " + this.y + ")";
    }
}

export default function myDefaultTest() {
    return 42;
}
