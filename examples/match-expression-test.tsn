// Test for match expression

// Test 1: Match with integer literals
const value1 = 2
const result1 = match value1 {
    1 => "one",
    2 => "two",
    3 => "three",
    _ => "other"
}
print("Test 1 - match (2):")
print(result1)

// Test 2: Match with string literals
const color = "red"
const hex = match color {
    "red" => "#FF0000",
    "green" => "#00FF00",
    "blue" => "#0000FF",
    _ => "#000000"
}
print("Test 2 - match color:")
print(hex)

// Test 3: Match with boolean
const flag = true
const status = match flag {
    true => "enabled",
    false => "disabled",
    _ => "dynamic"
}
print("Test 3 - match boolean:")
print(status)

// Test 4: Match with null
const nullable: int? = null
const message = match nullable {
    null => "no value",
    _ => "has value"
}
print("Test 4 - match null:")
print(message)

// Test 5: Wildcard default case
const unknownValue = 999
const category = match unknownValue {
    1 => "first",
    2 => "second",
    _ => "default"
}
print("Test 5 - wildcard:")
print(category)

print("Match expression tests completed!")
