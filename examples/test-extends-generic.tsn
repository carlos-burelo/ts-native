// Test extending generic class

class Base<T> {
    private data: T | null

    constructor() {
        this.data = null
    }

    getData(): T | null {
        return this.data
    }
}

class Derived extends Base<int> {
    private value: int

    constructor() {
        super()
        this.value = 42
    }

    getValue(): int {
        return this.value
    }
}

const d = new Derived()
print("Value: " + d.getValue())
