
print("Starting verification...");

// Test 1: Array<int>
const a1: Array<int> = [1, 2, 3];
print("a1 length is:", a1.length);
if (a1.length != 3) throw "Length failed " + str.parse(a1.length);
print("Test 1 OK");

// Test 2: int[];
const a2: int[] = [10];
a2.push(20);
print("a2 length after push:", a2.length);
if (a2.length != 2) throw "Push failed";
print("Test 2 OK");

// Test 3: Array checks
if (Array.isArray(a1)) print("isArray OK");
else throw "isArray failed";
