extension StringUtils on str {
    shout(): str { return this + "!" }
    times(n: int): str {
        let result = ""
        let i = 0
        while (i < n) { result = result + this; i = i + 1 }
        return result
    }
    wordCount(): int {
        let count = 0
        let inWord = false
        let i = 0
        while (i < this.length) {
            const ch = this[i]
            if (ch !== " " && !inWord) { count = count + 1; inWord = true }
            else if (ch === " ") { inWord = false }
            i = i + 1
        }
        return count
    }
}

class Slot {
    value: int
    constructor(v: int) { this.value = v }
}

extension SlotOps on Slot {
    doubled(): int { return this.value * 2 }
    add(n: int): int { return this.value + n }
}

extension SlotAccessor on Slot {
    get label(): str { return "Slot(" + this.value + ")" }
    set label(s: str) { this.value = s.length }
}

extension IntUtils on int {
    isEven(): bool { return this % 2 === 0 }
    clamp(lo: int, hi: int): int {
        if (this < lo) { return lo }
        if (this > hi) { return hi }
        return this
    }
}

export function run(): void {
    print("\n══ 25. Extensions ══")

    assert("str shout",          "hello".shout() === "hello!")
    assert("str times",          "ab".times(3) === "ababab")
    assert("str wordCount",      "hello world foo".wordCount() === 3)

    const slot = new Slot(5)
    assert("slot doubled",       slot.doubled() === 10)
    assert("slot add",           slot.add(3) === 8)

    assert("slot getter label",  slot.label === "Slot(5)")
    slot.label = "hello"
    assert("slot setter label",  slot.value === 5)

    assert("int isEven true",    (4).isEven() === true)
    assert("int isEven false",   (7).isEven() === false)
    assert("int clamp lo",       (2).clamp(5, 10) === 5)
    assert("int clamp hi",       (15).clamp(5, 10) === 10)
    assert("int clamp mid",      (7).clamp(5, 10) === 7)
}
