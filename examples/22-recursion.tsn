function isEven2(n: int): bool {
    if (n === 0) return true
    return isOdd2(n - 1)
}
function isOdd2(n: int): bool {
    if (n === 0) return false
    return isEven2(n - 1)
}

export function run(): void {
    print("\n══ 22. Recursion ══")

    function fib(n: int): int {
        if (n <= 1) return n
        return fib(n - 1) + fib(n - 2)
    }
    assert("fib 0",  fib(0) === 0)
    assert("fib 1",  fib(1) === 1)
    assert("fib 10", fib(10) === 55)

    function power(base: int, exp: int): int {
        if (exp === 0) return 1
        return base * power(base, exp - 1)
    }
    assert("power 2^0",  power(2, 0) === 1)
    assert("power 2^10", power(2, 10) === 1024)
    assert("power 0^5",  power(0, 5) === 0)

    assert("mutual even 4", isEven2(4))
    assert("mutual odd 7",  isOdd2(7))
    assert("mutual even 0", isEven2(0))
}
