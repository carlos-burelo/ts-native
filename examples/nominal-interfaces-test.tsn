// Test: Nominal typing for interfaces
// Interfaces with same structure should NOT be assignable

interface Point {
    x: int
    y: int
}

interface Vector {
    x: int
    y: int
}

function distance(p: Point): int {
    return p.x + p.y
}

function magnitude(v: Vector): int {
    return v.x + v.y
}

// Test 1: Same interface should work
const p1: Point = { x: 1, y: 2 }
const result1: int = distance(p1)
print("Test 1 passed: distance(Point) = ")
print(result1)

// Test 2: Different interface with same structure should FAIL
const v1: Vector = { x: 3, y: 4 }
// This should cause a type error:
// distance(v1)  // ❌ Error: Vector is not assignable to Point

print("Test 2: Skipped (would cause compile error)")

// Test 3: Object literals should work (structural)
const result2: int = distance({ x: 5, y: 6 })
print("Test 3 passed: distance(literal) = ")
print(result2)

print("Nominal interface tests completed!")
