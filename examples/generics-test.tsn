// generics-test.tsn — Ultra-complete generics test
// Tests: generic classes, generic functions, type inference, explicit type args,
//        constraints, instanceof, typeof, nested generics, union + generics,
//        method-level type params, stdlib generics (Array<T>, Future<T>, Map<V>, Set<T>)

let passed = 0;
let failed = 0;

function check(label: str, result: bool): void {
    if (result) {
        passed = passed + 1;
    } else {
        failed = failed + 1;
        print("FAIL:", label);
    }
}

// ─── 1. Generic class ────────────────────────────────────────────────────────

class Box<T> {
    value: T;
    constructor(v: T) {
        this.value = v;
    }
    get(): T {
        return this.value;
    }
    map<U>(f: (v: T) => U): Box<U> {
        return new Box<U>(f(this.value));
    }
}

const intBox = new Box<int>(42);
check("Box<int>.get() === 42", intBox.get() === 42);
check("Box<int>.value === 42", intBox.value === 42);

const strBox = new Box<str>("hello");
check("Box<str>.get() === hello", strBox.get() === "hello");

const mapped = intBox.map<str>((v) => v.toString());
check("Box.map<str> result is str", mapped.get() === "42");

const inferredBox = new Box(100);
check("Box inferred int", inferredBox.get() === 100);

// ─── 2. Generic function — explicit type args ─────────────────────────────

function identity<T>(x: T): T {
    return x;
}

check("identity<int>(5) === 5", identity<int>(5) === 5);
check("identity<str>(hi) === hi", identity<str>("hi") === "hi");
check("identity<bool>(true)", identity<bool>(true) === true);

// ─── 3. Generic function — inferred type args ─────────────────────────────

function wrap<T>(x: T): T[] {
    return [x];
}

const wrapped = wrap(7);
check("wrap(7)[0] === 7", wrapped[0] === 7);
check("wrap(7).length === 1", wrapped.length === 1);

const wrappedStr = wrap("tsn");
check("wrap('tsn')[0] === 'tsn'", wrappedStr[0] === "tsn");

// ─── 4. Generic function — multi-param inference ─────────────────────────

function pair<A, B>(a: A, b: B): A[] {
    return [a];
}

const p = pair(1, "x");
check("pair(1, 'x')[0] === 1", p[0] === 1);

// ─── 5. Array<T> stdlib generics ─────────────────────────────────────────

const nums: int[] = [1, 2, 3, 4, 5];

const doubled = nums.map((x) => x * 2);
check("Array.map doubles", doubled[0] === 2 && doubled[4] === 10);

const evens = nums.filter((x) => x % 2 === 0);
check("Array.filter evens", evens.length === 2 && evens[0] === 2);

const sum = nums.reduce((acc, x) => acc + x, 0);
check("Array.reduce sum", sum === 15);

const found = nums.find((x) => x > 3);
check("Array.find > 3", found === 4);

const idx = nums.findIndex((x) => x === 3);
check("Array.findIndex === 3", idx === 2);

check("Array.every > 0", nums.every((x) => x > 0));
check("Array.some > 4", nums.some((x) => x > 4));
check("Array.includes 3", nums.includes(3));

const sliced = nums.slice(1, 3);
check("Array.slice [1..3]", sliced.length === 2 && sliced[0] === 2);

const concat = nums.concat([6, 7]);
check("Array.concat length", concat.length === 7);

const reversed = [3, 1, 2].reverse();
check("Array.reverse", reversed[0] === 2);

const mut: int[] = [3, 1, 4];
mut.push(5);
check("Array.push length", mut.length === 4);

const popped = mut.pop();
check("Array.pop value", popped === 5);
check("Array.pop length after", mut.length === 3);

const shifted = mut.shift();
check("Array.shift value", shifted === 3);

mut.unshift(10);
check("Array.unshift value", mut[0] === 10);

const atNeg = nums.at(-1);
check("Array.at(-1)", atNeg === 5);

const joined = ["a", "b", "c"].join("-");
check("Array.join", joined === "a-b-c");

const flat = [[1, 2], [3, 4]].flat();
check("Array.flat", flat.length === 4 && flat[0] === 1);

const flatMapped = [1, 2, 3].flatMap((x) => [x, x * 10]);
check("Array.flatMap", flatMapped.length === 6 && flatMapped[1] === 10);

const filled = [0, 0, 0].fill(9);
check("Array.fill", filled[0] === 9 && filled[2] === 9);

const sorted = [3, 1, 2].sort((a, b) => a - b);
check("Array.sort", sorted[0] === 1 && sorted[2] === 3);

// ─── 6. Map<V> stdlib generics ────────────────────────────────────────────

const m = new Map<int>();
m.set("a", 1);
m.set("b", 2);
m.set("c", 3);
check("Map.has('a')", m.has("a"));
check("Map.get('b') === 2", m.get("b") === 2);
check("Map.size === 3", m.size === 3);

m.delete("c");
check("Map.delete size", m.size === 2);

const mapKeys = m.keys();
check("Map.keys length", mapKeys.length === 2);

const mapVals = m.values();
check("Map.values has element", mapVals.length === 2);

m.clear();
check("Map.clear size", m.size === 0);

// ─── 7. Set<T> stdlib generics ────────────────────────────────────────────

const s = new Set<int>();
s.add(1);
s.add(2);
s.add(2);  // duplicate
s.add(3);
check("Set.size (unique)", s.size === 3);
check("Set.has(2)", s.has(2));
check("Set.has(5) false", !s.has(5));

s.delete(2);
check("Set.delete", !s.has(2) && s.size === 2);

const setVals = s.values();
check("Set.values length", setVals.length === 2);

s.clear();
check("Set.clear size", s.size === 0);

// ─── 8. Generic class with multiple operations ────────────────────────────

class Container<T> {
    items: T[];
    constructor() {
        this.items = [];
    }
    add(item: T): void {
        this.items.push(item);
    }
    get size(): int {
        return this.items.length;
    }
    getAll(): T[] {
        return this.items;
    }
    find(pred: (x: T) => bool): T | null {
        for (const item of this.items) {
            if (pred(item)) {
                return item;
            }
        }
        return null;
    }
}

const intContainer = new Container<int>();
intContainer.add(10);
intContainer.add(20);
intContainer.add(30);
check("Container.size === 3", intContainer.size === 3);
check("Container.getAll[1] === 20", intContainer.getAll()[1] === 20);
check("Container.find 20", intContainer.find((x) => x === 20) === 20);
check("Container.find not found", intContainer.find((x) => x === 99) === null);

const strContainer = new Container<str>();
strContainer.add("x");
strContainer.add("y");
check("Container<str>.size === 2", strContainer.size === 2);
check("Container<str>.getAll[0] === 'x'", strContainer.getAll()[0] === "x");

// ─── 9. Generic with constraint (extends) ────────────────────────────────

interface Printable {
    toString(): str;
}

function printAll<T extends Printable>(items: T[]): str {
    return items.map((i) => i.toString()).join(", ");
}

check("printAll ints", printAll<int>([1, 2, 3]) === "1, 2, 3");
check("printAll strs", printAll<str>(["a", "b"]) === "a, b");

// ─── 10. Nested generics ──────────────────────────────────────────────────

const nested: int[][] = [[1, 2], [3, 4], [5, 6]];
check("nested[0][1] === 2", nested[0][1] === 2);
check("nested.length === 3", nested.length === 3);

const nestedMapped = nested.map((row) => row.map((x) => x * 2));
check("nested map[1][0] === 6", nestedMapped[1][0] === 6);

// Generic class nesting — runtime value check
const innerBox = new Box<int>(99);
check("inner Box.get() === 99", innerBox.get() === 99);
check("inner Box instanceof Box", innerBox instanceof Box);

// ─── 11. Generic + optional types ────────────────────────────────────────

function firstOrDefault<T>(arr: T[], def: T): T {
    if (arr.length === 0) {
        return def;
    }
    return arr[0];
}

check("firstOrDefault non-empty", firstOrDefault<int>([5, 6], 0) === 5);
check("firstOrDefault empty", firstOrDefault<int>([], 99) === 99);
check("firstOrDefault str", firstOrDefault<str>([], "default") === "default");

// ─── 12. instanceof with generic types ───────────────────────────────────

const boxInst = new Box<int>(1);
check("instanceof Box", boxInst instanceof Box);

const contInst = new Container<str>();
check("instanceof Container", contInst instanceof Container);

// ─── 13. typeof checks ───────────────────────────────────────────────────

const typeofInt = intBox.get();
check("typeof Box<int>.get() is int", typeof typeofInt === "int");

const typeofStr = strBox.get();
check("typeof Box<str>.get() is str", typeof typeofStr === "str");

// ─── 14. Generic function with callbacks ─────────────────────────────────

function zipWith<A, B, C>(a: A[], b: B[], f: (x: A, y: B) => C): C[] {
    const result: C[] = [];
    const len = a.length < b.length ? a.length : b.length;
    for (let i = 0; i < len; i = i + 1) {
        result.push(f(a[i], b[i]));
    }
    return result;
}

const zipped = zipWith<int, str, str>([1, 2, 3], ["a", "b", "c"], (n, s) => n.toString() + s);
check("zipWith length", zipped.length === 3);
check("zipWith[0] === '1a'", zipped[0] === "1a");
check("zipWith[2] === '3c'", zipped[2] === "3c");

// ─── 15. Generic null-safe retrieval ─────────────────────────────────────

function getOrElse<T>(val: T | null, def: T): T {
    if (val === null) {
        return def;
    }
    return val;
}

check("getOrElse non-null", getOrElse<int>(5, 0) === 5);
check("getOrElse null", getOrElse<int>(null, 42) === 42);
check("getOrElse str", getOrElse<str>(null, "fallback") === "fallback");

// ─── 16. sortBy using generic + callback ─────────────────────────────────

function sortBy<T>(arr: T[], key: (x: T) => int): T[] {
    return arr.slice(0).sort((a, b) => key(a) - key(b));
}

class Person {
    name: str;
    age: int;
    constructor(n: str, a: int) {
        this.name = n;
        this.age = a;
    }
}

const people = [new Person("Charlie", 30), new Person("Alice", 25), new Person("Bob", 35)];
const byAge = sortBy<Person>(people, (p) => p.age);
check("sortBy age[0].name === Alice", byAge[0].name === "Alice");
check("sortBy age[2].name === Bob", byAge[2].name === "Bob");

// ─── 17. Generic flatten ─────────────────────────────────────────────────

function flatten<T>(arrs: T[][]): T[] {
    const result: T[] = [];
    for (const arr of arrs) {
        for (const item of arr) {
            result.push(item);
        }
    }
    return result;
}

const flat2 = flatten<int>([[1, 2], [3, 4], [5]]);
check("flatten length", flat2.length === 5);
check("flatten[0] === 1", flat2[0] === 1);
check("flatten[4] === 5", flat2[4] === 5);

// ─── 18. Generic pipeline ────────────────────────────────────────────────

function pipe<T, U, V>(x: T, f: (a: T) => U, g: (b: U) => V): V {
    return g(f(x));
}

const result = pipe<int, str, int>(42, (n) => n.toString(), (s) => s.length);
check("pipe int->str->int", result === 2);

// ─── 19. Generic memoize (closure pattern) ───────────────────────────────

function memoize<T, U>(f: (x: T) => U): (x: T) => U {
    const cache = new Map<U>();
    return (x: T) => {
        const key = str.from(x);
        const cached = cache.get(key);
        if (cached !== null) {
            return cached;
        }
        const val = f(x);
        cache.set(key, val);
        return val;
    };
}

let callCount = 0;
const expensiveDouble = memoize<int, int>((x) => {
    callCount = callCount + 1;
    return x * 2;
});
check("memoize first call", expensiveDouble(5) === 10);
check("memoize second call same result", expensiveDouble(5) === 10);
check("memoize different arg", expensiveDouble(3) === 6);
check("memoize called at most twice", callCount <= 2);

// ─── Summary ─────────────────────────────────────────────────────────────

print(`\nGenerics Test: PASSED ${passed} / FAILED ${failed}`);
if (failed === 0) {
    print("ALL GENERIC TESTS PASSED");
} else {
    print(`${failed} tests FAILED`);
}
