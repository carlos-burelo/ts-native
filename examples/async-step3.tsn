/**
 * Test 3: Async con await de otra async
 */
async function inner(): int {
    print("  ✅ Inner: Ejecutando")
    return 42
}

async function outer(): void {
    print("✅ TEST 3: Outer antes de await")
    const value = await inner()
    print("✅ TEST 3: Outer después de await, valor = " + value.toString())
}

outer()
print("=".repeat(60))
