print("Total:  " + total.toString())
print("Passed: " + passed.toString())
print("Failed: " + (total - passed).toString())
print("")

if (passed === total) {
    print("✓✓✓ ALL TESTS PASSED ✓✓✓")
} else {
    print("✗ " + (total - passed).toString() + " TEST(S) FAILED")
}
