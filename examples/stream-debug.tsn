import { Stream } from 'std:io'

print("Test 1: Create Stream")
const s = new Stream()
print("Stream created: " + (s !== null).toString())

print("Test 2: Check read method")
const hasRead = s.read !== undefined
print("s.read exists: " + hasRead.toString())

if (hasRead) {
    print("Test 3: Call read")
    const res = s.read(1)
    print("read returned: '" + res + "'")
}
