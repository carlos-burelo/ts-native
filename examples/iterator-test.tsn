// Test completo del sistema de iteradores profesional

print("=== Test 1: ArrayIterator directo ===")
const arr = [10, 20, 30, 40, 50]
const iterator = arr.getIterator()

while (iterator.hasNext()) {
    const value = iterator.next()
    print(value)
}

print("\n=== Test 2: For...of usa iteradores internamente ===")
const letters = ["a", "b", "c"]
for (const letter of letters) {
    print(letter)
}

print("\n=== Test 3: For...of con break ===")
const nums = [1, 2, 3, 4, 5]
for (const n of nums) {
    if (n === 3) {
        break
    }
    print(n)
}

print("\n=== Test 4: For...of con continue ===")
for (const x of [10, 20, 30, 40, 50]) {
    if (x === 30) {
        continue
    }
    print(x)
}

print("\n=== Test 5: Nested for...of ===")
const matrix = [[1, 2], [3, 4], [5, 6]]
for (const row of matrix) {
    for (const val of row) {
        print(val)
    }
}

print("\n=== Test 6: For await...of ===")
async function testAsync(): void {
    const data = [100, 200, 300]
    for await (const d of data) {
        print(d)
    }
}

testAsync()

print("\nTodos los tests de iteradores pasaron!")
