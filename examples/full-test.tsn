function add(a: int, b: int): int {
	return a + b
}

function multiply(x: int, y: int): int {
	return x * y
}

function greet(name: str): str {
	return 'Hello, ' + name + '!'
}

function formatUser(name: str, age: int, active: bool): str {
	const status = active ? 'active' : 'inactive'
	return name + ' (age: ' + age + ', status: ' + status + ')'
}

function isEven(n: int): bool {
	return n % 2 === 0
}

function getSquare(n: int): int {
	return n * n
}

