function fibonacci(n: int): int {
	if (n <= 1) {
		return n
	}
	return fibonacci(n - 1) + fibonacci(n - 2)
}

function factorial(n: int): int {
	if (n <= 1) {
		return 1
	}
	return n * factorial(n - 1)
}

function isPrime(n: int): bool {
	if (n <= 1) {
		return false
	}
	if (n === 2) {
		return true
	}
	if (n % 2 === 0) {
		return false
	}

	let i = 3
	while (i * i <= n) {
		if (n % i === 0) {
			return false
		}
		i = i + 2
	}
	return true
}

