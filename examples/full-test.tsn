function checkValue(n: int): str {
	if (n > 0) {
		return 'positive'
	} else if (n < 0) {
		return 'negative'
	} else {
		return 'zero'
	}
}

function classify(age: int): str {
	if (age < 13) {
		return 'child'
	} else {
		if (age < 20) {
			return 'teenager'
		} else {
			if (age < 65) {
				return 'adult'
			} else {
				return 'senior'
			}
		}
	}
}

function countDown(n: int): int {
	let count = n
	while (count > 0) {
		count = count - 1
	}
	return count
}

function sumRange(start: int, end: int): int {
	let total = 0
	for (let i = start; i <= end; i = i + 1) {
		total = total + i
	}
	return total
}

const max = 10
const min = 5
const result = max > min ? max : min

function getStatus(active: bool): str {
	if (active) {
		return 'ONLINE'
	} else {
		return 'OFFLINE'
	}
}

function getGrade(score: int): char {
	if (score >= 90) {
		return 'A'
	} else if (score >= 80) {
		return 'B'
	} else if (score >= 70) {
		return 'C'
	} else {
		return 'F'
	}
}

class Point {
	x: int
	y: int

	constructor(x: int, y: int) {
		this.x = x
		this.y = y
	}

	distance(): int {
		const dx = this.x * this.x
		const dy = this.y * this.y
		return dx + dy
	}

	toString(): str {
		return 'Point(' + this.x + ', ' + this.y + ')'
	}
}

class Counter {
	private value: int

	constructor(initial: int) {
		this.value = initial
	}

	increment(): int {
		this.value = this.value + 1

		return this.value
	}

	decrement(): int {
		this.value = this.value - 1
		return this.value
	}

	getValue(): int {
		return this.value
	}

	reset(): void {
		this.value = 0
	}
}

class MathHelper {
	static PI: float = 3.14159

	static abs(n: int): int {
		if (n < 0) {
			return -n
		} else {
			return n
		}
	}

	static max(a: int, b: int): int {
		if (a > b) {
			return a
		} else {
			return b
		}
	}

	static min(a: int, b: int): int {
		if (a < b) {
			return a
		} else {
			return b
		}
	}
}

// Inheritance
class Rectangle {
	width: int
	height: int

	constructor(width: int, height: int) {
		this.width = width
		this.height = height
	}

	area(): int {
		return this.width * this.height
	}

	perimeter(): int {
		const sum = this.width + this.height
		return 2 * sum
	}
}

class Square extends Rectangle {
	constructor(side: int) {
		super(side, side)
	}

	getSide(): int {
		return this.width
	}
}

