// stdlib-test.tsn — Integration tests for all TSN standard library modules.
//
// Run with: cargo run --bin tsn -- examples/stdlib-test.tsn

// ─── imports ───────────────────────────────────────────────────────────────
import { Math, }     from 'std:math'
import { JSON }     from 'std:json'
import { console }  from 'std:console'
import { Path }     from 'std:path'
import { Reflect }  from 'std:reflect'
import { Time }     from 'std:time'
import { Sys }      from 'std:sys'
import { sleep }    from 'std:async'
import { writeFile, readText, exists, mkdir, readDir, remove, removeAll } from 'std:fs'
import { Response } from 'std:http'
import { Now, Instant, PlainDate, Duration } from 'std:temporal'

// ─── test harness ──────────────────────────────────────────────────────────
let passed = 0
let failed = 0


function test(desc: str, testFn: () => bool): void {
    try {
        const ok = testFn()
        if (ok) {
            passed++
            print("  ✓ " + desc)
        } else {
            print("  \x1b[31m✗\x1b[0m " + desc + " (returned false)")
            failed++
        }
    } catch (err) {
        print("  \x1b[31m✗\x1b[0m " + desc + " (threw: " + err + ")")
        failed++
    }
}

print("╔══════════════════════════════════════════╗")
print("║        TSN STDLIB INTEGRATION TESTS       ║")
print("╚══════════════════════════════════════════╝")

// ═══════════════════════════════════════════════════════════════════
// std:math
// ═══════════════════════════════════════════════════════════════════
print("\n█ std:math")

test("Math.abs(-5)", () => Math.abs(-5) === 5)
test("Math.abs(3)", () => Math.abs(3) === 3)
test("Math.floor(2.9)", () => Math.floor(2.9) === 2)
test("Math.ceil(2.1)", () => Math.ceil(2.1) === 3)
test("Math.round(2.5)", () => Math.round(2.5) === 3)
test("Math.round(2.4)", () => Math.round(2.4) === 2)
test("Math.trunc(3.9)", () => Math.trunc(3.9) === 3)
test("Math.sqrt(9)", () => Math.sqrt(9) === 3.0)
test("Math.pow(2, 10)", () => Math.pow(2, 10) === 1024.0)
test("Math.min(3, 7)", () => Math.min(3, 7) === 3)
test("Math.max(3, 7)", () => Math.max(3, 7) === 7)
test("Math.sign(-4)", () => Math.sign(-4) === -1)
test("Math.sign(4)", () => Math.sign(4) === 1)
test("Math.PI > 3.14", () => Math.PI > 3.14)
test("Math.E  > 2.71", () => Math.E  > 2.71)
test("Math.log(Math.E) ≈ 1", () => (Math.log(Math.E) as float) > 0.99 && (Math.log(Math.E) as float) < 1.01)
test("Math.sin(0) === 0", () => Math.sin(0) === 0.0)
test("Math.cos(0) === 1", () => Math.cos(0) === 1.0)
const rnd = Math.random()
test("Math.random in [0,1)", () => rnd >= 0.0 && rnd < 1.0)

// ═══════════════════════════════════════════════════════════════════
// std:json
// ═══════════════════════════════════════════════════════════════════
print("\n█ std:json")

const obj = JSON.parse("{\"x\": 1, \"y\": 2}")
test("JSON.parse object", () => obj.x === 1)
test("JSON.parse object.y", () => obj.y === 2)

const arr = JSON.parse("[10, 20, 30]")
test("JSON.parse array[0]", () => arr[0] === 10)
test("JSON.parse array[2]", () => arr[2] === 30)

const nested = JSON.parse("{\"a\": {\"b\": true}}")
test("JSON.parse nested bool", () => nested.a.b === true)

const jsonStr = JSON.stringify(42)
test("JSON.stringify int", () => jsonStr === "42")

const jsonObj = JSON.stringify({name: "tsn", version: 1})
test("JSON.stringify object not empty", () => jsonObj !== "")

// ═══════════════════════════════════════════════════════════════════
// std:console
// ═══════════════════════════════════════════════════════════════════
print("\n█ std:console")

// console.log/warn/error are side-effects; just call them and check they don't throw.
print("  [console.log works]")
console.warn("  [console.warn works]")
console.error("  [console.error works]")
test("console methods exist", () => true)

// ═══════════════════════════════════════════════════════════════════
// std:path
// ═══════════════════════════════════════════════════════════════════
print("\n█ std:path")

const joined = Path.join("foo", "bar", "baz.txt")
test("Path.join produces non-empty", () => joined !== "")

const dir = Path.dirname("/home/user/file.txt")
test("Path.dirname", () => dir === "/home/user" || dir === "\\home\\user")

const base = Path.basename("/home/user/file.txt")
test("Path.basename", () => base === "file.txt")

const ext = Path.extname("archive.tar.gz")
test("Path.extname", () => ext === ".gz")

const normed = Path.normalize("a/b/../c")
test("Path.normalize a/b/../c → a/c", () => normed === "a/c" || normed === "a\\c")

test("Path.sep is non-empty", () => Path.sep !== "")
test("Path.delimiter is non-empty", () => Path.delimiter !== "")

const abs1 = Path.isAbsolute(Sys.cwd())
const abs2 = Path.isAbsolute("relative/path")
test("Path.isAbsolute Sys.cwd()", () => abs1 === true)
test("Path.isAbsolute relative", () => abs2 === false)

// ═══════════════════════════════════════════════════════════════════
// std:reflect
// ═══════════════════════════════════════════════════════════════════
print("\n█ std:reflect")

Reflect.defineMetadata("role",  "admin", "user:1")
Reflect.defineMetadata("score", "100",   "user:1")

const role  = Reflect.getMetadata("role",  "user:1")
const score = Reflect.getMetadata("score", "user:1")
const missing = Reflect.getMetadata("email", "user:1")

test("Reflect.defineMetadata + getMetadata", () => role === "admin")
test("Reflect.getMetadata second key", () => score === "100")
test("Reflect.getMetadata missing → null", () => missing === null)
test("Reflect.hasMetadata true", () => Reflect.hasMetadata("role",  "user:1") === true)
test("Reflect.hasMetadata false", () => Reflect.hasMetadata("email", "user:1") === false)

const keys = Reflect.getMetadataKeys("user:1")
test("Reflect.getMetadataKeys length ≥ 2", () => keys.length >= 2)

// ═══════════════════════════════════════════════════════════════════
// std:time
// ═══════════════════════════════════════════════════════════════════
print("\n█ std:time")

const t1 = Time.now()
const t2 = Time.now()
test("Time.now returns float", () => t1 > 0.0)
test("Time.now is monotonic-ish", () => t2 >= t1)

const ms = Time.millis()
test("Time.millis > 0", () => ms > 0.0)

const iso = Time.toISOString(0)
test("Time.toISOString(0) non-empty", () => iso !== "")

// ═══════════════════════════════════════════════════════════════════
// std:sys
// ═══════════════════════════════════════════════════════════════════
print("\n█ std:sys")

const platform = Sys.platform()
test("Sys.platform non-empty", () => platform !== "")
test("Sys.platform known OS", () => platform === "windows" || platform === "linux" || platform === "macos")

const cwd = Sys.cwd()
test("Sys.cwd non-empty", () => cwd !== "")

const args = Sys.args()
test("Sys.args is array", () => args.length >= 0)

const sysNow = Sys.now()
test("Sys.now > 0", () => sysNow > 0.0)

Sys.setEnv("TSN_TEST_VAR", "hello")
const envVal = Sys.env("TSN_TEST_VAR")
test("Sys.setEnv + Sys.env", () => envVal === "hello")

const missingEnv = Sys.env("TSN_DEFINITELY_NOT_SET_XYZ")


test("Sys.env missing → null", () => missingEnv === null)

// ═══════════════════════════════════════════════════════════════════
// std:async  (sleep returns a future; await it)
// ═══════════════════════════════════════════════════════════════════
print("\n█ std:async")

async function testAsync(): void {
    const before = Time.millis()
    await sleep(10)
    const after  = Time.millis()
    test("sleep(10) awaited without error", () => after >= before)
}

testAsync()

// ═══════════════════════════════════════════════════════════════════
// std:fs  (write → read → exists → remove)
// ═══════════════════════════════════════════════════════════════════
print("\n█ std:fs")

async function testFs(): void {
    const tmpPath = "tsn-stdlib-test-tmp.txt"

    await writeFile(tmpPath, "hello from tsn")
    const exists1 = exists(tmpPath)
    test("exists after writeFile", () => exists1 === true)

    const content = await readText(tmpPath)
    test("readText content", () => content === "hello from tsn")

    await remove(tmpPath)
    const exists2 = exists(tmpPath)
    test("exists after remove", () => exists2 === false)

    // readDir
    const tmpDir = "tsn-stdlib-test-dir"
    await mkdir(tmpDir)
    const exists3 = exists(tmpDir)
    test("mkdir creates dir", () => exists3 === true)

    await writeFile(tmpDir + "/a.txt", "a")
    await writeFile(tmpDir + "/b.txt", "b")
    const dir = await readDir(tmpDir)

    test("readDir returns entries", () => dir.length >= 2)

    await removeAll(tmpDir)
    test("removeAll dir", () => exists(tmpDir) === false)
}

testFs()

// ═══════════════════════════════════════════════════════════════════
// std:http — Response constructor (no network needed)
// ═══════════════════════════════════════════════════════════════════
print("\n█ std:http — Response")

const resp = Response.from("{\"ok\": true}", 200)
test("Response.status", () => resp.status === 200)
test("Response.ok", () => resp.ok === true)

const resp4xx = Response.from("Not found", 404)
test("Response 404 ok=false", () => resp4xx.ok === false)
test("Response 404 status", () => resp4xx.status === 404)

// ═══════════════════════════════════════════════════════════════════
// std:temporal  (no network, pure computation)
// ═══════════════════════════════════════════════════════════════════
print("\n█ std:temporal")

// Now — basic namespace calls
const nowInstant = Now.instant()
test("Now.instant() non-null", () => nowInstant !== null)

const tzId = Now.timeZoneId()
test("Now.timeZoneId() non-empty", () => tzId !== "")

// Instant — from epoch
const epoch = Instant.fromEpochSeconds(0)
test("Instant.fromEpochSeconds(0)", () => epoch.epochSeconds === 0)
test("Instant.epochMilliseconds(0)", () => epoch.epochMilliseconds === 0)

const msEpoch = Instant.fromEpochMilliseconds(1000)
test("Instant.fromEpochMilliseconds(1000).epochSeconds", () => msEpoch.epochSeconds === 1)

// Instant.compare
const a = Instant.fromEpochSeconds(100)
const b = Instant.fromEpochSeconds(200)
const cmp = Instant.compare(a, b)
test("Instant.compare(earlier, later) < 0", () => cmp < 0)

// PlainDate — from string
const date = PlainDate.from("2024-03-15")
test("PlainDate.from year", () => date.year === 2024)
test("PlainDate.from month", () => date.month === 3)
test("PlainDate.from day", () => date.day === 15)

// Duration — from string
const dur = Duration.from("P1Y2M3DT4H5M6S")
test("Duration.from years", () => dur.years === 1)
test("Duration.from months", () => dur.months === 2)
test("Duration.from days", () => dur.days === 3)

// ═══════════════════════════════════════════════════════════════════
// Summary
// ═══════════════════════════════════════════════════════════════════
print("\n══════════════════════════════════════════════")

// The async tests (std:async, std:fs) run after this line.
// The synchronous results are already complete.
print("Sync tests done. Async tests (sleep, fs) running in background.")
print("  passed (sync): " + passed)
print("  failed (sync): " + failed)
print("══════════════════════════════════════════════")
