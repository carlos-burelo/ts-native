// API Expansion Verification

function assert(cond: bool, msg: str) {
    if (!cond) {
        throw "Assertion failed: " + msg;
    }
}

// Str methods
let s = "Hello World";
assert(s.at(0) == "H", "str.at(0)");
assert(s.at(-1) == "d", "str.at(-1)");
assert(s.codePointAt(0) == 72, "str.codePointAt(0)");
assert(s.contains("Hello"), "str.contains(Hello)");
assert(s.contains("foo") == false, "str.contains(foo)");

// Int methods
assert(int.isInteger(42), "int.isInteger(42)");
assert(int.isInteger(4.2) == false, "int.isInteger(4.2)");
assert(int.isInteger("42") == false, "int.isInteger('42')");

// Float methods
assert(float.isNaN(0.0/0.0), "float.isNaN");
assert(float.isFinite(1.23), "float.isFinite(1.23)");
assert((1.0).isInteger(), "1.0.isInteger()");
assert((1.5).isInteger() == false, "1.5.isInteger()");

// Array methods
let arr = [1, 2, 3, 4, 5];
assert(arr.at(0) == 1, "arr.at(0)");
assert(arr.at(-1) == 5, "arr.at(-1)");

let doubled = arr.map((x: int) => x * 2);
assert(doubled.length == 5, "map length");
assert(doubled[0] == 2, "map[0]");
assert(doubled[4] == 10, "map[4]");

let filtered = arr.filter((x: int) => x > 3);
assert(filtered.length == 2, "filter length");
assert(filtered[0] == 4, "filter[0]");

let sum = arr.reduce((acc: int, x: int) => acc + x, 0);
assert(sum == 15, "reduce sum");

let found = arr.find((x: int) => x > 3);
assert(found == 4, "find > 3");

let foundIdx = arr.findIndex((x: int) => x > 3);
assert(foundIdx == 3, "findIndex > 3");

let even = arr.some((x: int) => x % 2 == 0);
assert(even, "some even");

let allPositive = arr.every((x: int) => x > 0);
assert(allPositive, "every positive");

let reversed = [1, 2, 3].reverse();
assert(reversed[0] == 3, "reverse[0]");

let filled = [1, 1, 1].fill(9);
assert(filled[0] == 9 && filled[1] == 9 && filled[2] == 9, "fill");

let sorted = [3, 1, 2].sort();
assert(sorted[0] == 1 && sorted[1] == 2 && sorted[2] == 3, "sort default");

let sortedDesc = [1, 2, 3].sort((a: int, b: int) => b - a);
assert(sortedDesc[0] == 3 && sortedDesc[1] == 2 && sortedDesc[2] == 1, "sort custom");

let flat = [1, [2, 3], 4].flat();
assert(flat.length == 4, "flat length");
assert(flat[1] == 2, "flat[1]");

let spliced = [1, 2, 3, 4];
let removed = spliced.splice(1, 2, 9, 8);
assert(removed.length == 2 && removed[0] == 2 && removed[1] == 3, "splice removed");
assert(spliced.length == 4 && spliced[1] == 9 && spliced[2] == 8, "splice updated");

print("All API expansion tests passed! Barbarian!");
