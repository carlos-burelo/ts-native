// Test Builder inheritance

class Builder {
    protected value: int = 0
    protected name: str = ""

    reset(): this {
        this.value = 0
        this.name = ""
        return this
    }

    setValue(v: int): this {
        this.value = v
        return this
    }

    getValue(): int {
        return this.value
    }
}

class AdvancedBuilder<T> extends Builder {
    private data: T | null

    constructor() {
        super()
        this.data = null
    }

    setData(d: T): this {
        this.data = d
        return this
    }

    getData(): T | null {
        return this.data
    }

    reset(): this {
        this.value = 0
        this.name = ""
        this.data = null
        return this
    }
}

class NumberBuilder extends AdvancedBuilder<int> {
    private multiplier: int

    constructor() {
        super()
        this.multiplier = 1
    }

    setMultiplier(m: int): this {
        this.multiplier = m
        return this
    }

    compute(): int {
        const d = this.getData()
        if (d === null) {
            return this.value * this.multiplier
        }
        return d * this.multiplier
    }

    double(): this {
        this.multiplier = this.multiplier * 2
        return this
    }
}

const nb = new NumberBuilder()
nb.setValue(10).setData(5).setMultiplier(3)
print("Result: " + nb.compute())
