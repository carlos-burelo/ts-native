/**
 * TEST BÁSICO DE ASYNC/AWAIT
 */

// TEST 1: Async simple
async function test1(): void {
    print("Test 1: inicio")
    print("Test 1: fin")
}

// TEST 2: Await de async
async function test2(): void {
    print("\nTest 2: antes await")
    await test1()
    print("Test 2: después await")
}

// TEST 3: Async con retorno de valor
async function test3Returns(): int {
    print("\nTest 3: retornando 42")
    return 42
}

// TEST 4: Await de función con retorno
async function test4AwaitReturn(): void {
    print("\nTest 4: await de función con retorno")
    const value = await test3Returns()
    print("Test 4: valor recibido = " + value.toString())
}

// TEST 5: Try/catch básico
async function test5TryCatch(): void {
    print("\nTest 5: try/catch")
    try {
        print("Test 5: en try")
        await test1()
        print("Test 5: try exitoso")
    } catch (e: dynamic) {
        print("Test 5: en catch")
    }
}

// TEST 6: Throw error
async function test6Throws(): void {
    print("\nTest 6: función que lanza")
    throw Error("Error de prueba")
    print("Test 6: NO debe aparecer")
}

// TEST 7: Catch de error
async function test7CatchError(): void {
    print("\nTest 7: catch de error")
    try {
        await test6Throws()
        print("Test 7: NO debe llegar aquí")
    } catch (e: dynamic) {
        print("Test 7: error capturado")
    }
    print("Test 7: después del catch")
}

// MAIN EJECUTA TODOS LOS TESTS
async function runTests(): void {
    print("========== INICIO TESTS ==========\n")
    
    print("Ejecutando test 1...")
    await test1()
    
    print("\nEjecutando test 2...")
    await test2()
    
    print("\nEjecutando test 3...")
    const val = await test3Returns()
    print("Main: test3 retornó " + val.toString())
    
    print("\nEjecutando test 4...")
    await test4AwaitReturn()
    
    print("\nEjecutando test 5...")
    await test5TryCatch()
    
    print("\nEjecutando test 7...")
    await test7CatchError()
    
    print("\n========== FIN TESTS ==========")
}

function main(): void {
    print("Main: llamando runTests()")
    runTests()
    print("Main: después de llamar runTests()")
}

main()
