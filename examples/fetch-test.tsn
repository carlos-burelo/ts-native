import { fetch, HTTP, Method } from "std:http";

async function testFetch() {
    print("--- Testing fetch(url) ---");
    try {
        const resp = await fetch("https://httpbin.org/get");
        print("Status: " + resp.status.toString());
        print("OK: " + resp.ok.toString());
        print("Body length: " + resp.body.length.toString());
    } catch (e) {
        print("Error in fetch(url): " + e.toString());
    }

    print("--- Testing fetch(url, init) with POST ---");
    try {
        const resp = await fetch("https://httpbin.org/post", {
            method: Method.POST,
            headers: {
                "Content-Type": "application/json",
                "X-Custom-Header": "TSN-Native"
            },
            body: '{"test": "data"}'
        });
        print("Status: " + resp.status.toString());
        print("OK: " + resp.ok.toString());
    } catch (e) {
        print("Error in fetch(url, init): " + e.toString());
    }

    print("--- Testing HTTP.get(url) ---");
    try {
        const resp = await HTTP.get("https://httpbin.org/get");
        print("Status: " + resp.status.toString());
    } catch (e) {
        print("Error in HTTP.get: " + e.toString());
    }

    print("Done.");
}

testFetch();
