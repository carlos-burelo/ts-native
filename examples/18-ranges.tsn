import { Range } from "std:collections"

export function run(): void {
    print("\n══ 18. Ranges ══")

    const r1 = 0..5
    const r2 = 1..=5

    assert("range start",          r1.start === 0)
    assert("range end excl",       r1.end === 5)
    assert("range length excl",    r1.length === 5)
    assert("range incl length",    r2.length === 5)
    assert("range contains true",  r1.contains(3))
    assert("range contains false", !r1.contains(5))
    assert("range incl contains",  r2.contains(5))

    const arr2 = (0..4).toArray()
    assert("toArray len",   arr2.length === 4)
    assert("toArray first", arr2[0] === 0)
    assert("toArray last",  arr2[3] === 3)

    const stepped = (0..10).step(3)
    assert("step len",   stepped.length === 4)
    assert("step value", stepped[1] === 3)

    let rangeSum = 0
    for (const i of 1..=10) {
        rangeSum = rangeSum + i
    }
    assert("range for-of sum", rangeSum === 55)

    const r3 = Range.from(5, 10)
    assert("Range.from start", r3.start === 5)
    assert("Range.from end",   r3.end === 10)
}
