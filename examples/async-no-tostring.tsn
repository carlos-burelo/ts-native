/**
 * Test sin toString()
 */

async function getValue(): int {
    print("  [getValue] Retornando 42")
    return 42
}

async function testAwait(): void {
    print("[1] ANTES del await")
    const result = await getValue()
    print("[2] DESPUÉS del await")
    print("[3] Valor recibido (sin toString)")
    print("[4] Final de testAwait")
}

async function main(): void {
    print("=== INICIO ===")
    await testAwait()
    print("=== FIN DE MAIN ===")
}

main()
