// Accessor Decorator Test
// Tests getter and setter decorators

print("====================================")
print("ACCESSOR DECORATOR TEST")
print("====================================\n")

let log: str = ""

// ============================================================================
// DECORATOR FUNCTIONS
// ============================================================================

function logAccessor(value, context) {
  print("Accessor Decorator Called:")
  print("  Kind: " + context.kind)
  print("  Name: " + context.name)
  print("  Static: " + context.static)
  log = log + "[@" + context.kind + ":" + context.name + "] "
  return value
}

function trackedAccessor(value, context) {
  print("Tracked Accessor Decorator:")
  print("  Adding initializer for: " + context.name)
  
  context.addInitializer(() => {
    print("  Initializer executed for: " + context.name)
    log = log + "[init:" + context.name + "] "
  })
  
  return value
}

// ============================================================================
// TEST 1: SIMPLE GETTER DECORATOR
// ============================================================================

print("\n[Test 1] Simple Getter Decorator")
log = ""

class GetterTest {
  value_field: int = 42
  
  @logAccessor
  get value(): int {
    print("  Getter called")
    return this.value_field
  }
}

let obj1 = new GetterTest()
let val1 = obj1.value
print("Log: " + log + "\n")

// ============================================================================
// TEST 2: SIMPLE SETTER DECORATOR
// ============================================================================

print("[Test 2] Simple Setter Decorator")
log = ""

class SetterTest {
  value_field: int = 0
  
  @logAccessor
  set value(v: int): void {
    print("  Setter called with: " + v)
    this.value_field = v
  }
  
  get value(): int {
    return this.value_field
  }
}

let obj2 = new SetterTest()
obj2.value = 100
print("Log: " + log + "\n")

// ============================================================================
// TEST 3: GETTER AND SETTER PAIR
// ============================================================================

print("[Test 3] Getter and Setter Pair")
log = ""

class PairTest {
  name_field: str = "default"
  
  @logAccessor
  get name(): str {
    print("  Getter called")
    return this.name_field
  }
  
  @logAccessor
  set name(n: str): void {
    print("  Setter called with: " + n)
    this.name_field = n
  }
}

let obj3 = new PairTest()
let name3 = obj3.name
obj3.name = "Alice"
print("Log: " + log + "\n")

// ============================================================================
// TEST 4: STATIC ACCESSOR
// ============================================================================

print("[Test 4] Static Accessor")
log = ""

class StaticAccessorTest {
  static count_field: int = 0
  
  @logAccessor
  static get count(): int {
    print("  Static getter called")
    return StaticAccessorTest.count_field
  }
  
  @logAccessor
  static set count(c: int): void {
    print("  Static setter called with: " + c)
    StaticAccessorTest.count_field = c
  }
}

let count4 = StaticAccessorTest.count
StaticAccessorTest.count = 5
print("Log: " + log + "\n")

// ============================================================================
// TEST 5: ACCESSOR WITH INITIALIZER
// ============================================================================

print("[Test 5] Accessor with Initializer")
log = ""

class InitAccessorTest {
  data_field: str = "initial"
  
  @trackedAccessor
  get data(): str {
    return this.data_field
  }
  
  @trackedAccessor
  set data(d: str): void {
    this.data_field = d
  }
}

print("Creating instance...")
let obj5 = new InitAccessorTest()
print("Log: " + log + "\n")

// ============================================================================
// TEST 6: MULTIPLE DECORATORS ON ACCESSOR
// ============================================================================

print("[Test 6] Multiple Decorators on Accessor")
log = ""

function dec1(value, context) {
  log = log + "[dec1] "
  return value
}

function dec2(value, context) {
  log = log + "[dec2] "
  return value
}

class MultiDecoratorAccessorTest {
  x_field: int = 0
  
  @dec1
  @dec2
  get x(): int {
    return this.x_field
  }
}

let obj6 = new MultiDecoratorAccessorTest()
let x6 = obj6.x
print("Log: " + log + "\n")

// ============================================================================
// SUMMARY
// ============================================================================

print("====================================")
print("ACCESSOR DECORATOR TEST COMPLETE")
print("====================================")
