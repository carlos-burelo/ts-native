// Test: Nominal typing for classes
// Classes with same structure should NOT be assignable

class UserId {
    value: int

    constructor(v: int) {
        this.value = v
    }

    toString(): str {
        return "UserId"
    }
}

class ProductId {
    value: int

    constructor(v: int) {
        this.value = v
    }

    toString(): str {
        return "ProductId"
    }
}

function getUser(id: UserId): void {
    print("Getting user with ID: ")
    print(id.value)
}

function getProduct(id: ProductId): void {
    print("Getting product with ID: ")
    print(id.value)
}

// Test 1: Same class should work
const userId: UserId = new UserId(42)
getUser(userId)
print("Test 1 passed")

// Test 2: Different class with same structure should FAIL
const productId: ProductId = new ProductId(100)
// This should cause a type error:
// getUser(productId)  // ❌ Error: ProductId is not assignable to UserId

print("Test 2: Skipped (would cause compile error)")

// Test 3: Can't assign int directly to UserId
// This should also fail:
// const badId: UserId = 42  // ❌ Error: int is not assignable to UserId

print("Nominal class tests completed!")
