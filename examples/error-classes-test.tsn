// error-classes-test.tsn — Error, TypeError, RangeError as proper classes

// 1. Instantiation does NOT terminate the program
const e1 = new Error("something went wrong");
print(e1.name);     // Error
print(e1.message);  // something went wrong
print(e1.toString()); // Error: something went wrong

const e2 = new TypeError("expected a string");
print(e2.name);     // TypeError
print(e2.message);  // expected a string

const e3 = new RangeError("index out of bounds");
print(e3.name);     // RangeError

// 2. throw + catch round-trip preserves the instance
try {
    throw new Error("caught me");
} catch (err) {
    print(err.name);    // Error
    print(err.message); // caught me
    print(err.toString()); // Error: caught me
}

// 3. instanceof works
const myErr = new TypeError("bad type");
print(myErr instanceof TypeError); // true
print(myErr instanceof Error);     // true  (superclass chain)
print(myErr instanceof RangeError); // false

// 4. Subclass message via toString
try {
    throw new RangeError("too large");
} catch (err) {
    print(err.toString()); // RangeError: too large
}

print("all ok");
