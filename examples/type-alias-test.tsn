/**
 * Type Alias Test
 */

// Test 1: Simple type alias
type StringAlias = str
const s: StringAlias = "hello"

// Test 2: Number alias
type NumberAlias = int
const n: NumberAlias = 42

// Test 3: Function type alias
type BinaryOp = (a: int, b: int) => int

function add(a: int, b: int): int {
    return a + b
}

const op: BinaryOp = add
const result = op(10, 20)

