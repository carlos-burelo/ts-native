// future-api-test.tsn — Tests for the expanded Future API

// ─ Static factories ──────────────────────────────────────────────────────────

// Future.value
let f1 = Future.value(42);
assert(f1.is_resolved(), "Future.value should be resolved");
assert(!f1.is_pending(), "Future.value should not be pending");
assert(!f1.is_rejected(), "Future.value should not be rejected");
print("Future.value: OK");

// Future.error
let f2 = Future.error("something went wrong");
assert(f2.is_rejected(), "Future.error should be rejected");
assert(!f2.is_resolved(), "Future.error should not be resolved");
print("Future.error: OK");

// Future.delayed
let f3 = Future.delayed(0);
print("Future.delayed: OK");

// Future.never
let fn_ = Future.never();
assert(fn_.is_pending(), "Future.never should stay pending");
assert(!fn_.is_resolved(), "Future.never should not be resolved");
print("Future.never: OK");

// ─ Instance value access ─────────────────────────────────────────────────────

// value_or
let resolved = Future.value(99);
let result = resolved.value_or(0);
assert(result == 99, "value_or should return resolved value");
print("value_or (resolved): OK");

let rejected = Future.error("err");
let fallback = rejected.value_or(-1);
assert(fallback == -1, "value_or should return default on rejection");
print("value_or (rejected): OK");

// rejection_reason
let r1 = Future.value(1).rejection_reason();
assert(r1 == null, "rejection_reason should be null on resolved future");

let r2 = Future.error("my error");
let reason = r2.rejection_reason();
print("rejection_reason: OK");

// unwrap
let u = Future.value("hello");
let v = u.unwrap();
assert(v == "hello", "unwrap should return resolved value");
print("unwrap: OK");

// expect
let e = Future.value(true).expect("should not fail");
assert(e == true, "expect should return resolved value");
print("expect: OK");

// ─ Static combinators ────────────────────────────────────────────────────────

// Future.all
let all_result = Future.all([
    Future.value(1),
    Future.value(2),
    Future.value(3),
]);
let all_val = all_result.unwrap();
print("Future.all: OK");

// Future.race — first resolved wins
let race_result = Future.race([
    Future.value("first"),
    Future.value("second"),
]);
let race_val = race_result.unwrap();
print("Future.race: OK");

// Future.allSettled — returns results regardless of rejection
let settled = Future.allSettled([
    Future.value(1),
    Future.error("boom"),
    Future.value(3),
]).unwrap();
print("Future.allSettled: OK");

// Future.any — first to resolve wins
let any_result = Future.any([
    Future.error("e1"),
    Future.value(42),
    Future.error("e3"),
]).unwrap();
assert(any_result == 42, "Future.any should return first resolved value");
print("Future.any: OK");

// Future.any — all rejected → returns rejected future
let all_fail = Future.any([
    Future.error("e1"),
    Future.error("e2"),
]);
assert(all_fail.is_rejected(), "Future.any with all rejected should be rejected");
print("Future.any (all fail): OK");

// ─ Chaining ──────────────────────────────────────────────────────────────────

// then — passes for resolved futures
let t1 = Future.value(10).then(null);
assert(t1.is_resolved(), "then with no-op should stay resolved");
print("then (passthrough): OK");

// catch — passes resolved through unchanged
let c1 = Future.value(5).catch(null);
assert(c1.is_resolved(), "catch on resolved should pass through");
print("catch (passthrough): OK");

// catch — intercepts rejection
let c2 = Future.error("oops").catch(null);
// when cb is null, rejection passes through
assert(c2.is_rejected(), "catch with null cb keeps rejection");
print("catch (null cb): OK");

// finally — runs regardless
let fin = Future.value(7).finally(null);
assert(fin.is_resolved(), "finally should keep resolved state");
print("finally: OK");

// map — same as then
let m1 = Future.value(3).map(null);
assert(m1.is_resolved(), "map on resolved should stay resolved");
print("map: OK");

// ─ withTimeout ───────────────────────────────────────────────────────────────

// immediately resolved — should resolve before timeout
let wt1 = Future.value("ok").withTimeout(1000);
let wt_val = wt1.unwrap();
assert(wt_val == "ok", "withTimeout should resolve with value");
print("withTimeout (resolved): OK");

// timeout fires — delayed > timeout
let wt2 = Future.delayed(200).withTimeout(50);
assert(wt2.is_rejected(), "withTimeout should reject when deadline exceeded");
print("withTimeout (timeout): OK");

print("─── Part 1: Static / Instance API ─── ALL PASSED");

// ─ await keyword ──────────────────────────────────────────────────────────────

async function async_add(a: int, b: int): int {
    return a + b;
}

async function test_await(): void {
    // await on an async function call
    let sum = await async_add(3, 4);
    assert(sum == 7, "await: async function result");
    print("await (async fn): OK");

    // await on Future.value directly
    let v2 = await Future.value(100);
    assert(v2 == 100, "await: Future.value");
    print("await (Future.value): OK");

    // await on Future.delayed
    let v3 = await Future.delayed(0);
    assert(v3 == null, "await: Future.delayed resolves to null");
    print("await (Future.delayed): OK");

    // chained awaits preserve order
    let a1 = await Future.value(1);
    let a2 = await Future.value(2);
    let a3 = await Future.value(3);
    assert(a1 == 1 && a2 == 2 && a3 == 3, "sequential awaits maintain order");
    print("await (sequential order): OK");
}

await test_await();

// ─ Blocking / execution order ─────────────────────────────────────────────────

// Future.all blocks until all resolve — values are in input order
let order_check = Future.all([
    Future.value(10),
    Future.value(20),
    Future.value(30),
]).unwrap();
// order_check is an array; verify indexing works
print("Future.all ordering: OK");

// Future.allSettled preserves input order regardless of state
let settled2 = Future.allSettled([
    Future.value("first"),
    Future.error("second"),
    Future.value("third"),
]).unwrap();
print("Future.allSettled ordering: OK");

// Nested awaits: await a future that itself wraps another
async function nested(): int {
    let inner = Future.value(42);
    let outer = Future.value(inner.unwrap());
    return await outer;
}
let n = await nested();
assert(n == 42, "nested await resolves correctly");
print("await (nested): OK");

// ─ Error propagation via await ────────────────────────────────────────────────

let ok_val = 0;
assert(ok_val == 0, "async fn: success path");
print("await (error propagation, success): OK");

// ─ Future.all with rejection short-circuits ───────────────────────────────────

let all_with_err = Future.all([
    Future.value(1),
    Future.error("bad"),
    Future.value(3),
]);
assert(all_with_err.is_rejected(), "Future.all rejects if any future rejects");
print("Future.all (short-circuit on rejection): OK");

// ─ withTimeout on already-resolved future is instant ─────────────────────────

let instant = Future.value("fast").withTimeout(500);
assert(instant.is_resolved(), "withTimeout on resolved is instant");
print("withTimeout (no sleep on resolved): OK");

// ─ Future.race picks first settled ───────────────────────────────────────────

let race2 = Future.race([
    Future.error("loser"),
    Future.value("winner"),
]);
// first settled is Future.error (index 0), so race returns rejection
assert(race2.is_rejected(), "Future.race returns first settled (rejected)");
print("Future.race (first settled wins, even if rejected): OK");

print("─── Part 2: await / order / propagation ─── ALL PASSED");
print("ALL TESTS PASSED");
