import { IO, Stream } from 'std:io'

print("█ std:io extensions test")

// Stream test
const s = new Stream()
print("Stream created")

const data = s.read(10)
print("Stream read (placeholder): '" + data + "'")

s.write("hello")
print("Stream write (placeholder) called")

s.close()
print("Stream closed")

print("  ✓ Stream API basic usage works")
