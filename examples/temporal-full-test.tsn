import { Temporal } from "std:temporal";

function assert(condition: bool, message: str) {
    if (!condition) {
        print("  FAIL: " + message);
    } else {
        print("  ✓ " + message);
    }
}

print("--- TESTING TEMPORAL API V2 ---");

// 1. Instant
print("\n[1. Instant]");
let inst1 = Temporal.Instant.from("2024-03-21T10:00:00Z");
let inst2 = Temporal.Instant.from("2024-03-21T12:00:00Z");
assert(inst1.epochMilliseconds === 1711015200000, "from ISO");
assert(inst1.epochSeconds === 1711015200, "epochSeconds");
assert(inst1.toString() === "2024-03-21T10:00:00.000Z", "toString");
assert(Temporal.Instant.compare(inst1, inst2) === -1, "compare smaller");
assert(Temporal.Instant.compare(inst2, inst1) === 1, "compare larger");
assert(inst1.equals(Temporal.Instant.from("2024-03-21T10:00:00Z")), "equals");
let diffInst = inst1.until(inst2);
assert(diffInst.totalMilliseconds === 7200000, "until (2h)");
assert(diffInst.toString() === "PT2H", "until toString");

// 2. PlainDate
print("\n[2. PlainDate]");
let date = new Temporal.PlainDate(2024, 3, 21);
assert(date.year === 2024, "year");
assert(date.month === 3, "month");
assert(date.day === 21, "day");
assert(date.toString() === "2024-03-21", "toString");
assert(date.dayOfWeek === Temporal.DayOfWeek.Thursday, "dayOfWeek (Thursday)");
assert(date.inLeapYear === true, "inLeapYear (2024)");
assert(date.daysInMonth === 31, "daysInMonth (March)");
assert(date.dayOfYear === 81, "dayOfYear (March 21, leap year)");

let feb = new Temporal.PlainDate(2024, 2, 1);
assert(feb.daysInMonth === 29, "daysInMonth (Feb 2024)");
let febNorm = new Temporal.PlainDate(2023, 2, 1);
assert(febNorm.daysInMonth === 28, "daysInMonth (Feb 2023)");

let d1 = new Temporal.PlainDate(2022, 1, 1);
let d2 = new Temporal.PlainDate(2023, 1, 1);
let yDiff = d1.until(d2);
assert(yDiff.years === 1, "until (1 year)");
assert(yDiff.toString() === "P1Y5D", "until toString");

// 3. PlainTime
print("\n[3. PlainTime]");
let time = new Temporal.PlainTime(14, 30, 15, 500);
assert(time.hour === 14, "hour");
assert(time.minute === 30, "minute");
assert(time.second === 15, "second");
assert(time.millisecond === 500, "millisecond");
assert(time.toString() === "14:30:15.500", "toString");
let tStart = new Temporal.PlainTime(10, 0, 0);
let tEnd = new Temporal.PlainTime(11, 45, 30);
let tDiff = tStart.until(tEnd);
assert(tDiff.hours === 1 && tDiff.minutes === 45 && tDiff.seconds === 30, "until (1h 45m 30s)");
assert(tDiff.toString() === "PT1H45M30S", "until toString");

// 4. PlainDateTime
print("\n[4. PlainDateTime]");
let pdt = new Temporal.PlainDateTime(2024, 3, 21, 10, 0, 0);
assert(pdt.toString() === "2024-03-21T10:00:00.000", "toString");
let pd = pdt.toPlainDate();
assert(pd.year === 2024 && pd.month === 3 && pd.day === 21, "toPlainDate");
let pt = pdt.toPlainTime();
assert(pt.hour === 10 && pt.minute === 0, "toPlainTime");

// 5. Duration
print("\n[5. Duration]");
let dur = Temporal.Duration.from("P1Y2M3DT4H5M6.123S");
assert(dur.years === 1, "years");
assert(dur.months === 2, "months");
assert(dur.days === 3, "days");
assert(dur.hours === 4, "hours");
assert(dur.minutes === 5, "minutes");
assert(dur.seconds === 6, "seconds");
assert(dur.milliseconds === 123, "milliseconds");
assert(dur.toString() === "P1Y2M3DT4H5M6.123S", "toString");

let negDur = Temporal.Duration.from("-PT1H");
assert(negDur.totalMilliseconds === -3600000, "negative from");
assert(negDur.sign === -1, "sign");
assert(negDur.toString() === "-PT1H", "negative toString");

// 6. ZonedDateTime
print("\n[6. ZonedDateTime]");
let zdt = Temporal.ZonedDateTime.from("2024-03-21T10:00:00Z[America/New_York]");
assert(zdt.timeZone === "America/New_York", "timeZone");
assert(zdt.year === 2024, "year");
assert(zdt.toString() === "2024-03-21T10:00:00.000Z[America/New_York]", "toString");

// 7. Enums
print("\n[7. Enums]");
assert(Temporal.Month.March === 3, "Month.March");
assert(Temporal.DayOfWeek.Thursday === 4, "DayOfWeek.Thursday");

// 8. Now
print("\n[8. Now]");
let now = Temporal.Now.instant();
print("  Current instant: " + now.toString());
assert(now.epochMilliseconds > 0, "Now.instant()");
let nowDate = Temporal.Now.plainDateISO();
print("  Current date: " + nowDate.toString());
assert(nowDate.year >= 2024, "Now.plainDateISO()");

print("\n--- ALL TEMPORAL TESTS COMPLETED ---");
