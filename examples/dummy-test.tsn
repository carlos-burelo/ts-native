import DefaultFunc from 'std:dummy';
import { hello, Calculator, DUMMY_VERSION, Utils, Color, User, Point, Config } from 'std:dummy';

print("Testing ALL exportable declarations from dummy stdlib...");

// 1. Function
print("hello('World') = " + hello("World"));
if (hello("TSN") === "Hello, TSN from dummy stdlib!") {
    print("  ✓ function works");
}

// 2. Class
let calc = new Calculator();
print("calc.add(5, 7) = " + calc.add(5, 7));
if (calc.add(5, 7) === 12) {
    print("  ✓ class works");
}

// 3. Variable/Const
print("DUMMY_VERSION = " + DUMMY_VERSION);
if (DUMMY_VERSION === "1.0.0") {
    print("  ✓ const works");
}

// 4. Namespace
print("Utils.FOO = " + Utils.FOO);
if (Utils.FOO === "BAR") {
    print("  ✓ namespace works");
}

// 5. Enum
print("Color.Red = " + Color.Red);
if (Color.Red === 0) {
    print("  ✓ enum works");
}

// 6. Struct
let cfg: Config = { mode: "test", port: 8080 };
print("cfg.port = " + cfg.port);
if (cfg.port === 8080) {
    print("  ✓ struct works");
}

// 7. Interface / 8. TypeAlias (Type checking only)
let u: User = { id: 1, name: "Checker" };
let p: Point = { x: 10, y: 20 };
print("  ✓ interface and type alias resolved");

// 9. Default export
print("DefaultFunc() = " + DefaultFunc());
if (DefaultFunc() === "I am the default export") {
    print("  ✓ default export works");
}

print("ALL DECLARATION TESTS PASSED!");
