export function run(): void {
    print("\n══ 17. Map & Set ══")

    const map = new Map<int>()
    map.set("a", 1)
    map.set("b", 2)
    map.set("c", 3)
    assert("map size",       map.size === 3)
    assert("map get",        map.get("b") === 2)
    assert("map has",        map.has("c"))
    assert("map has false",  !map.has("z"))
    map.delete("b")
    assert("map after del",  map.size === 2)
    assert("map get null",   map.get("b") === null)
    const mk = map.keys()
    assert("map keys len",   mk.length === 2)
    const mv = map.values()
    assert("map values len", mv.length === 2)
    map.clear()
    assert("map clear",      map.size === 0)

    const set = new Set<str>()
    set.add("x")
    set.add("y")
    set.add("x")
    assert("set size dedup",   set.size === 2)
    assert("set has",          set.has("x"))
    assert("set has false",    !set.has("z"))
    set.delete("x")
    assert("set after delete", set.size === 1)
    set.clear()
    assert("set clear",        set.size === 0)
}
