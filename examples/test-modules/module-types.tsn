/**
 * Module exporting various type definitions
 */

export class Circle {
    radius: int

    constructor(radius: int) {
        this.radius = radius
    }

    area(): int {
        return 3 * this.radius * this.radius
    }
}

export class Rectangle {
    width: int
    height: int

    constructor(width: int, height: int) {
        this.width = width
        this.height = height
    }

    area(): int {
        return this.width * this.height
    }
}

export function getMaxSize(): int {
    return 1000
}
