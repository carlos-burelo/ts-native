/**
 * Module library with various exports
 */

// Named exports - functions (constants don't work in current runtime)
export function getPI(): float {
    return 3.14159
}

export function getVersion(): int {
    return 1
}

export function add(a: int, b: int): int {
    return a + b
}

export function multiply(x: int, y: int): int {
    return x * y
}

// Named exports - class
export class Calculator {
    value: int

    constructor(initial: int) {
        this.value = initial
    }

    add(n: int): Calculator {
        this.value = this.value + n
        return this
    }

    getResult(): int {
        return this.value
    }
}

// Internal function (not exported)
function internal(): int {
    return 42
}
