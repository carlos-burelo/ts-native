// Test for range literals

// Test 1: Exclusive range (0..10 means 0 to 9)
const range1 = 0..10
print("Test 1 - Exclusive range 0..10:")
for (const i in range1) {
    print(i)
}

// Test 2: Inclusive range (0..=10 means 0 to 10)
const range2 = 0..=5
print("Test 2 - Inclusive range 0..=5:")
for (const i in range2) {
    print(i)
}

print("Range literals tests completed!")
