// Test field initializer with generic and union

class GenericTest<T> {
    private data: T | null = null

    setData(d: T): void {
        this.data = d
    }

    getData(): T | null {
        return this.data
    }
}

const t = new GenericTest<int>()
print("Initial: " + t.getData())
t.setData(42)
print("After set: " + t.getData())
