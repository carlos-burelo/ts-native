import { e } from "any-type-removed-test";
/**
 * Union type test with classes
 */

class Dog {
    private name: str

    constructor(n: str) {
        this.name = n
    }

    makeSound(): str {
        return "Woof!"
    }

    getName(): str {
        return this.name
    }
}

class Cat {
    private name: str

    constructor(n: str) {
        this.name = n
    }

    makeSound(): str {
        return "Meow!"
    }

    getName(): str {
        return this.name
    }
}

type Pet = Dog | Cat

function greetPet(pet: Pet): str {
    const name = pet.getName()
    const sound = pet.makeSound()
    return name + " says " + sound
}

const dog = new Dog("Rex")
const cat = new Cat("Whiskers")

const pet1: Pet = dog
const pet2: Pet = cat

print(greetPet(pet1))
print(greetPet(pet2))

print("Union class test completed!")
