// builtins-test.tsn — exercises every builtin global




// ── I/O ───────────────────────────────────────────────────────────────────
print("print: hello");
print("print: multi", "arg", 42);
print("print: hello");
print("print: multi", "arg", true);

// ── Intrinsics ────────────────────────────────────────────────────────────
const t: float = perf_now();
print("perf_now:", t);
print("async_model:", async_model());
print("thread_id:", thread_id());

// ── Type introspection ────────────────────────────────────────────────────
print("type_of(42):", type_of(42));
print("type_of(3.14):", type_of(3.14));
print("type_of(\"hi\"):", type_of("hi"));
print("type_of(true):", type_of(true));
print("type_of(null):", type_of(null));

// ── dbg passthrough ───────────────────────────────────────────────────────
const x: int = dbg(99);
print("dbg returned:", x);

// ── assert (passing) ─────────────────────────────────────────────────────
assert(true, "should not fail");
assert(1 == 1, "math broken");
print("assert: passed");

// ── Future ────────────────────────────────────────────────────────────────
const fv = Future.value(123);
print("Future.value created:", type_of(fv));
const fe = Future.error("oops");
print("Future.error created:", type_of(fe));

// Instance methods
print("fv.is_pending():", fv.is_pending());
print("fv.is_resolved():", fv.is_resolved());
print("fv.is_rejected():", fv.is_rejected());
print("fv.value_or(0):", fv.value_or(0));
print("fe.is_rejected():", fe.is_rejected());
print("fe.rejection_reason():", fe.rejection_reason());
print("fe.value_or(-1):", fe.value_or(-1));

// Combinators
const results = Future.all([Future.value(1), Future.value(2), Future.value(3)]);
print("Future.all result type:", type_of(results));
const winner = Future.race([Future.value("fast"), Future.value("slow")]);
print("Future.race result type:", type_of(winner));

// ── Error classes ─────────────────────────────────────────────────────────
const e1 = new Error("something went wrong");
const e2 = new TypeError("expected str");
const e3 = new RangeError("index out of bounds");
print("Error name:", e1.name);
print("Error message:", e1.message);
print("Error.toString:", e1.toString());
print("TypeError name:", e2.name);
print("RangeError name:", e3.name);
// instanceof checks
print("e1 instanceof Error:", e1 instanceof Error);
print("e2 instanceof TypeError:", e2 instanceof TypeError);
print("e2 instanceof Error:", e2 instanceof Error);
print("e2 instanceof RangeError:", e2 instanceof RangeError);
// throw + catch
try {
    throw new RangeError("too large");
} catch (err) {
    print("caught:", err.toString());
}

// ── panic (last — terminates) ─────────────────────────────────────────────
print("about to panic...");
print("this line must NOT appear");
