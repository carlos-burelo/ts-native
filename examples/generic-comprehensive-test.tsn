/**
 * Comprehensive Generic Test
 */

// Basic generic function
function identity<T>(value: T): T {
    return value
}

// Test with explicit type arguments
const num: int = identity<int>(42)
const text: str = identity<str>("hello")
const flag: bool = identity<bool>(true)

// Generic function with multiple type parameters
function pair<A, B>(first: A, second: B): A {
    return first
}

const p1: str = pair<str, int>("key", 100)
const p2: int = pair<int, str>(200, "value")

// Generic function that returns second type
function second<A, B>(first: A, second: B): B {
    return second
}

const s1: int = second<str, int>("key", 100)
const s2: str = second<int, str>(200, "value")
