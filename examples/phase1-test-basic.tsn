/**
 * Phase 1 Optimizations Basic Test
 * Tests that optimized OpCodes are working correctly
 */

print("=== Phase 1 Optimizations Basic Test ===")
print("")

// Test 1: String length
print("Test 1: String Length (OP_STR_LENGTH)")
let message: str = "Hello World"
let len: int = message.length
print("Length: " + len)
print("")

// Test 2: Array length
print("Test 2: Array Length (OP_ARRAY_LENGTH)")
let numbers: int[] = [1, 2, 3, 4, 5]
let count: int = numbers.length
print("Count: " + count)
print("")

// Test 3: String concatenation
print("Test 3: String Concatenation (OP_ADD)")
let hello: str = "Hello"
let world: str = "World"
let combined: str = hello + " " + world
print(combined)
print("")

// Test 4: Null check
print("Test 4: Null Check (OP_IS_NULL)")
let nullable: str | null = null
if (nullable === null) {
    print("Null check works!")
}

let notnull: str | null = "value"
if (notnull !== null) {
    print("Not-null check works!")
}
print("")

// Test 5: typeof
print("Test 5: Typeof (OP_TYPEOF)")
let n: int = 42
let typeResult: str = typeof n
print("typeof 42 = " + typeResult)
print("")

print("All basic tests completed!")
