// ============================================================================
print("\n══ 3. String methods ══")

const s = "  Hello, World!  "
check("trim",           s.trim() === "Hello, World!")
check("trimStart",      s.trimStart() === "Hello, World!  ")
check("trimEnd",        s.trimEnd() === "  Hello, World!")
check("toUpperCase",    "hello".toUpperCase() === "HELLO")
check("toLowerCase",    "WORLD".toLowerCase() === "world")
check("includes",       "typescript".includes("script"))
check("not includes",   !"typescript".includes("java"))
check("startsWith",     "hello world".startsWith("hello"))
check("endsWith",       "hello world".endsWith("world"))
check("indexOf found",  "abcabc".indexOf("c") === 2)
check("indexOf none",   "abcabc".indexOf("z") === -1)
check("slice",          "hello world".slice(6, 11) === "world")
check("slice neg",      "hello world".slice(-5) === "world")
check("replace",        "foo bar foo".replace("foo", "baz") === "baz bar foo")
check("replaceAll",     "foo bar foo".replaceAll("foo", "baz") === "baz bar baz")
check("split",          "a,b,c".split(",").length === 3)
check("split parts",    "a,b,c".split(",")[1] === "b")
check("repeat",         "ab".repeat(3) === "ababab")
check("padStart",       "5".padStart(3, "0") === "005")
check("padEnd",         "5".padEnd(3, "0") === "500")
check("length",         "hello".length === 5)
check("charAt",         "hello".charAt(1) === "e")
check("charCode A",     "A".charCode() === 65)
check("concat",         "Hello".concat(" World") === "Hello World")
check("substr 2 3",     "abcdef".substr(2, 3) === "cde")
check("substr 1",       "abcdef".substr(1) === "bcdef")
check("isEmpty true",   "".isEmpty())
check("isEmpty false",  !"hi".isEmpty())
check("isBlank true",   "   ".isBlank())
check("isBlank false",  !"hi".isBlank())
check("isDigit true",   "7".isDigit())
check("isDigit false",  !"a".isDigit())
check("isLetter true",  "z".isLetter())
check("isLetter false", !" ".isLetter())
check("reverse",        "abc".reverse() === "cba")
check("capitalize",     "hello".capitalize() === "Hello")
check("lines",          "a\nb\nc".lines().length === 3)
check("words",          "  foo bar  ".words().length === 2)
check("str.from int",   str.from(42) === "42")
check("str.from bool",  str.from(true) === "true")
check("str.EMPTY",      str.EMPTY === "")
check("str.fromCharCode", str.fromCharCode(72, 105) === "Hi")
check("str.join sep",   str.join(["a", "b", "c"], "-") === "a-b-c")
check("str.join empty", str.join([], ",") === "")

// ============================================================================
