// ============================================================================
// PRODUCTION READINESS TEST — TSN Language
// Tests edge cases across every major feature.
// All assertions must pass; print statements confirm progress.
// ============================================================================

import { Range } from "std:collections"

// ─── Helpers ─────────────────────────────────────────────────────────────────

let _passed = 0
let _failed = 0

function check(label: str, cond: bool): void {
    if (cond) {
        _passed = _passed + 1
    } else {
        _failed = _failed + 1
        print("FAIL: " + label)
    }
}

// ============================================================================
// 1. PRIMITIVE ARITHMETIC EDGE CASES
// ============================================================================
print("\n══ 1. Arithmetic edge cases ══")

check("int add",          1 + 2 === 3)
check("int sub negative", 3 - 5 === -2)
check("int mul zero",     42 * 0 === 0)
check("int div",          10 / 2 === 5)
check("int mod",          17 % 5 === 2)
check("int mod negative", -7 % 3 === -1)
check("int power",        2 ** 10 === 1024)
check("float add",        0.1 + 0.2 > 0.29 && 0.1 + 0.2 < 0.31)
check("float div",        1.0 / 3.0 > 0.333 && 1.0 / 3.0 < 0.334)
check("unary neg",        -(5) === -5)
check("double neg",       -(-3) === 3)
check("precedence *+",    2 + 3 * 4 === 14)
check("precedence parens",(2 + 3) * 4 === 20)
check("bitwise and",      (12 & 10) === 8)
check("bitwise or",       (12 | 3) === 15)
check("bitwise xor",      (12 ^ 10) === 6)
check("bitwise not",      ~0 === -1)
check("left shift",       1 << 4 === 16)
check("right shift",      64 >> 2 === 16)

// ============================================================================
// 2. BOOLEAN LOGIC EDGE CASES
// ============================================================================
print("\n══ 2. Boolean edge cases ══")

check("and short-circuit", (false && (1/0 === 0)) === false)
check("or short-circuit",  true  || (1/0 === 0) === true)
check("not not",           !!true === true)
check("not false",         !false === true)
check("not true",          !true === false)
check("not eq",            !(1 === 2) === true)
check("not neq",           !(1 === 1) === false)
check("triple eq str",     "abc" === "abc")
check("triple neq str",    "abc" !== "def")
check("triple eq null",    null === null)
check("triple neq null",   null !== 0)

// ============================================================================
