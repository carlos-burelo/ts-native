print("\n══ 24. Record type ══")

const scores: Record<str, int> = {
    "alice": 95,
    "bob": 87,
    "charlie": 72
}
check("record get alice",   scores["alice"] === 95)
check("record get bob",     scores["bob"] === 87)
check("record get charlie", scores["charlie"] === 72)

