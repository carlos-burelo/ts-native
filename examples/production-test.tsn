// ============================================================================
// 5. ARRAY METHODS — COMPLETE COVERAGE
// ============================================================================
print("\n══ 5. Array methods ══")

const nums = [3, 1, 4, 1, 5, 9, 2, 6]
const strs = ["banana", "apple", "cherry"]

check("length",       nums.length === 8)
check("indexOf",      nums.indexOf(5) === 4)
check("indexOf none", nums.indexOf(99) === -1)
check("includes",     nums.includes(9))
check("includes not", !nums.includes(99))
check("slice",        nums.slice(2, 5).length === 3)
check("slice first",  nums.slice(0, 3)[0] === 3)
check("concat",       [1, 2].concat([3, 4]).length === 4)
check("join",         [1, 2, 3].join("-") === "1-2-3")
check("join default", [1, 2, 3].join() === "1,2,3")

const doubled = nums.map((n) => n * 2)
check("map length",   doubled.length === 8)
check("map value",    doubled[0] === 6)

const evens = nums.filter((n) => n % 2 === 0)
check("filter",       evens.length === 3)    // 4, 2, 6

const sum = nums.reduce((acc, n) => acc + n, 0)
check("reduce sum",   sum === 31)

const found = nums.find((n) => n > 5)
check("find first",   found === 9)

const fi = nums.findIndex((n) => n > 5)
check("findIndex",    fi === 5)

check("some",         nums.some((n) => n > 8))
check("some false",   !nums.some((n) => n > 100))
check("every",        [2, 4, 6].every((n) => n % 2 === 0))
check("every false",  ![2, 4, 5].every((n) => n % 2 === 0))

const sorted = strs.sort()
check("sort alpha",   sorted[0] === "apple")


const rev = [1, 2, 3].reverse()
check("reverse arr",  rev[0] === 3)

const flat = [[1, 2], [3, 4]].flat()
check("flat",         flat.length === 4)
check("flat value",   flat[2] === 3)

const fm = [[1, 2], [3]].flatMap((a) => a)
check("flatMap",      fm.length === 3)

// forEach (side-effect check via counter)
let counter = 0
[10, 20, 30].forEach((n) => { counter = counter + n })
check("forEach",      counter === 60)

// push / pop
const mut = [1, 2, 3]
mut.push(4)
check("push",         mut.length === 4)
check("push value",   mut[3] === 4)
const popped = mut.pop()
check("pop value",    popped === 4)
check("pop length",   mut.length === 3)

// spread array
const spread = [...[1, 2], ...[3, 4]]
check("spread array", spread.length === 4)
check("spread value", spread[2] === 3)

// ============================================================================
// 6. DESTRUCTURING — EDGE CASES
// ============================================================================
print("\n══ 6. Destructuring ══")

// Object basic
const obj1 = { a: 1, b: 2, c: 3 }
const { a, b } = obj1
check("obj destr basic", a === 1 && b === 2)

// Rename
const { a: renamed } = obj1
check("obj destr rename", renamed === 1)

// Default value (missing key)
const { name = "default", age = 0 } = { name: "Alice" }
check("obj destr default name", name === "Alice")
check("obj destr default age",  age === 0)

// Nested
const nested = { point: { x: 10, y: 20 } }
const { point: { x: nx, y: ny } } = nested
check("nested obj destr", nx === 10 && ny === 20)

// Array basic
const [f1, f2, f3] = [10, 20, 30]
check("arr destr basic", f1 === 10 && f3 === 30)

// Skip with _
const [skip1, _, skip3] = [100, 200, 300]
check("arr destr skip", skip1 === 100 && skip3 === 300)

// Rest
const [head, ...tail] = [1, 2, 3, 4]
check("rest head",   head === 1)
check("rest tail",   tail.length === 3)
check("rest value",  tail[0] === 2)

// Nested array-in-object
const data = { coords: [5, 6] }
const { coords: [cx, cy] } = data
check("nested arr-in-obj", cx === 5 && cy === 6)

// Object spread
const base = { x: 1, y: 2 }
const ext  = { ...base, z: 3 }
check("obj spread x", ext.x === 1)
check("obj spread z", ext.z === 3)

// ============================================================================
// 7. CLOSURES & HIGHER-ORDER FUNCTIONS
// ============================================================================
print("\n══ 7. Closures ══")

function makeAdder(n: int): (int) => int {
    return (x: int) => x + n
}
const add5 = makeAdder(5)
const add10 = makeAdder(10)
check("closure add5",   add5(3) === 8)
check("closure add10",  add10(3) === 13)
check("closure independent", add5(0) !== add10(0))

// Closure over mutable state
function makeCounter(): () => int {
    let c = 0
    return () => {
        c = c + 1
        return c
    }
}
const cnt1 = makeCounter()
const cnt2 = makeCounter()
check("counter1 first",  cnt1() === 1)
check("counter1 second", cnt1() === 2)
check("counter2 fresh",  cnt2() === 1)  // independent state

// Higher-order: compose
function compose<A, B, C>(f: (a:B) => C, g: (b:A) => B): (c:A) => C {
    return (x: A) => f(g(x))
}
const double = (n: int) => n * 2
const inc    = (n: int) => n + 1
const doubleInc = compose(double, inc)
check("compose", doubleInc(4) === 10)  // (4+1)*2

// ============================================================================
// 8. OPTIONAL CHAINING & NULLISH COALESCING
// ============================================================================
print("\n══ 8. Null safety ══")

interface Address {
    city: str
    zip?: int
}
interface Profile {
    name: str
    address?: Address
}

const p1: Profile? = { name: "Alice", address: { city: "NY" } }
const p2: Profile? = { name: "Bob" }
const p3: Profile? = null

check("?. non-null chain",   p1?.address?.city === "NY")
check("?. missing nested",   p2?.address?.city === null)
check("?. null root",        p3?.name === null)
check("?? left non-null",    (42 ?? 0) === 42)
check("?? left null",        (null ?? 99) === 99)
check("?. + ??",             p3?.name ?? "anon" === "anon")
check("chain ?? fallback",   p2?.address?.city ?? "dynamic" === "dynamic")
check("?? chained",          (null ?? null ?? 7) === 7)

// ============================================================================
// 9. CONTROL FLOW EDGE CASES
// ============================================================================
print("\n══ 9. Control flow ══")

// Nested ternary
function classify(n: int): str {
    return n < 0 ? "neg" : n === 0 ? "zero" : "pos"
}
check("nested ternary neg",  classify(-1) === "neg")
check("nested ternary zero", classify(0) === "zero")
check("nested ternary pos",  classify(1) === "pos")

// while with break
function firstAbove(arr: int[], threshold: int): int {
    let i = 0
    let result = -1
    while (i < arr.length) {
        if (arr[i] > threshold) {
            result = arr[i]
            break
        }
        i = i + 1
    }
    return result
}
check("while break", firstAbove([1, 2, 10, 3], 5) === 10)

// for loop with continue
function sumOdds(max: int): int {
    let total = 0
    for (let i = 0; i <= max; i = i + 1) {
        if (i % 2 === 0) continue
        total = total + i
    }
    return total
}
check("for continue", sumOdds(10) === 25)  // 1+3+5+7+9

// for-of array
let forOfSum = 0
for (const n of [10, 20, 30]) {
    forOfSum = forOfSum + n
}
check("for-of sum", forOfSum === 60)

// for-of with break
let forOfBreak = 0
for (const n of [1, 2, 3, 4, 5]) {
    if (n === 3) break
    forOfBreak = forOfBreak + n
}
check("for-of break", forOfBreak === 3)  // 1+2

// for-in object
const obj2 = { x: 1, y: 2, z: 3 }
let keyCount = 0
for (const k in obj2) {
    keyCount = keyCount + 1
}
check("for-in key count", keyCount === 3)

// ============================================================================
// 10. MATCH EXPRESSIONS
// ============================================================================
print("\n══ 10. Match expressions ══")

function describeNum(n: int): str {
    return match (n) {
        0 => "zero",
        1 => "one",
        2 | 3 => "two or three",
        _ => "other"
    }
}const flat: any[]
check("match 0",     describeNum(0) === "zero")
check("match 1",     describeNum(1) === "one")
check("match 2",     describeNum(2) === "two or three")
check("match 3",     describeNum(3) === "two or three")
check("match other", describeNum(99) === "other")

// Match with boolean expression
function httpStatus(code: int): str {
    return match (code) {
        200 => "OK",
        404 => "Not Found",
        500 => "Server Error",
        _ => "Unknown"
    }
}
check("match 200", httpStatus(200) === "OK")
check("match 404", httpStatus(404) === "Not Found")
check("match _",   httpStatus(302) === "Unknown")

// ============================================================================
// 11. ERROR HANDLING EDGE CASES
// ============================================================================
print("\n══ 11. Error handling ══")

// Basic try/catch
function safeDivide(a: int, b: int): int {
    try {
        if (b === 0) throw new RangeError("division by zero")
        return a / b
    } catch (e) {
        return -1
    }
}
check("try no error",      safeDivide(10, 2) === 5)
check("try catch returns", safeDivide(10, 0) === -1)

// Catch preserves error type
let caughtName = ""
try {
    throw new TypeError("bad type")
} catch (e) {
    caughtName = e.name
}
check("catch TypeError name", caughtName === "TypeError")

// instanceof in catch
let isRangeError = false
try {
    throw new RangeError("too big")
} catch (e) {
    isRangeError = e instanceof RangeError
}
check("catch instanceof", isRangeError)

// Nested try/catch
let innerCaught = false
let outerCaught = false
try {
    try {
        throw new Error("inner")
    } catch (e) {
        innerCaught = true
        // re-throw
        throw e
    }
} catch (e) {
    outerCaught = true
}
check("nested try inner caught", innerCaught)
check("nested try rethrow",      outerCaught)

// Custom error class
class ValidationError extends Error {
    field: str

    constructor(field: str, msg: str) {
        super(msg)
        this.name = "ValidationError"
        this.field = field
    }
}

let ve: ValidationError? = null
try {
    throw new ValidationError("email", "invalid format")
} catch (e) {
    ve = e
}
check("custom error name",    ve?.name === "ValidationError")
check("custom error message", ve?.message === "invalid format")
check("custom error field",   ve?.field === "email")
check("custom instanceof Error", ve instanceof Error)

// try/finally: finally always runs
let finallyRan = false
function withFinally(): int {
    try {
        return 42
    } finally {
        finallyRan = true
    }
}
const fres = withFinally()
check("finally return value", fres === 42)
check("finally ran",          finallyRan)

// ============================================================================
// 12. CLASSES — EDGE CASES
// ============================================================================
print("\n══ 12. Classes ══")

// Getter/setter
class Temperature {
    private _celsius: float

    constructor(c: float) {
        this._celsius = c
    }

    get celsius(): float { return this._celsius }
    set celsius(v: float) { this._celsius = v }
    get fahrenheit(): float { return this._celsius * 1.8 + 32.0 }
}

const t = new Temperature(100.0)
check("getter celsius",     t.celsius === 100.0)
check("getter fahrenheit",  t.fahrenheit === 212.0)
t.celsius = 0.0
check("setter works",       t.celsius === 0.0)
check("fahrenheit updated", t.fahrenheit === 32.0)

// Inheritance chain: 3 levels
class Animal {
    name: str
    constructor(n: str) { this.name = n }
    speak(): str { return "..." }
    toString(): str { return `Animal(${this.name})` }
}

class Dog extends Animal {
    constructor(n: str) { super(n) }
    override speak(): str { return "Woof" }
}

class PoliceDog extends Dog {
    badge: int
    constructor(n: str, badge: int) {
        super(n)
        this.badge = badge
    }
    override speak(): str { return super.speak() + "!" }
}

const a = new Animal("generic")
const d = new Dog("Rex")
const pd = new PoliceDog("K9", 42)

check("animal speak",      a.speak() === "...")
check("dog speak",         d.speak() === "Woof")
check("police dog speak",  pd.speak() === "Woof!")
check("police dog badge",  pd.badge === 42)
check("police dog name",   pd.name === "K9")
check("instanceof PoliceDog", pd instanceof PoliceDog)
check("instanceof Dog",       pd instanceof Dog)
check("instanceof Animal",    pd instanceof Animal)
check("dog not PoliceDog",    !(d instanceof PoliceDog))

// Static fields and methods
class IdGen {
    private static _next: int = 1
    static next(): int {
        const id = IdGen._next
        IdGen._next = IdGen._next + 1
        return id
    }
    static reset(): void { IdGen._next = 1 }
}

check("static method 1", IdGen.next() === 1)
check("static method 2", IdGen.next() === 2)
check("static method 3", IdGen.next() === 3)
IdGen.reset()
check("static reset",    IdGen.next() === 1)

// Abstract class enforcement
abstract class Shape {
    abstract area(): float
    describe(): str { return `shape with area ${this.area()}` }
}

class Circle extends Shape {
    r: float
    constructor(r: float) { this.r = r }
    override area(): float { return 3.14159 * this.r * this.r }
}

class Rect extends Shape {
    w: float
    h: float
    constructor(w: float, h: float) { this.w = w; this.h = h }
    override area(): float { return this.w * this.h }
}

const circ = new Circle(1.0)
const rect2 = new Rect(3.0, 4.0)
check("circle area",    circ.area() > 3.14 && circ.area() < 3.15)
check("rect area",      rect2.area() === 12.0)
check("abstract describe", circ.describe().includes("shape with area"))

// ============================================================================
// 13. INTERFACES & STRUCTURAL TYPING
// ============================================================================
print("\n══ 13. Interfaces ══")

interface Printable {
    toString(): str
}

interface Serializable {
    serialize(): str
}

// Multiple interface implementation
class Config implements Printable, Serializable {
    key: str
    value: int

    constructor(k: str, v: int) {
        this.key = k
        this.value = v
    }

    toString(): str { return `${this.key}=${this.value}` }
    serialize(): str { return `{"${this.key}":${this.value}}` }
}

const cfg = new Config("timeout", 30)
check("interface toString",   cfg.toString() === "timeout=30")
check("interface serialize",  cfg.serialize() === `{"timeout":30}`)

// Structural typing: object literal satisfies interface
function printThing(p: Printable): str {
    return p.toString()
}
check("structural typing", printThing(cfg) === "timeout=30")

// Interface with optional fields
interface Options {
    verbose?: bool
    maxRetries?: int
    tag: str
}

function runWith(opts: Options): str {
    const v = opts.verbose ?? false
    const r = opts.maxRetries ?? 3
    return `${opts.tag}:v=${v}:r=${r}`
}

check("opts defaults", runWith({ tag: "job1" }) === "job1:v=false:r=3")
check("opts partial",  runWith({ tag: "job2", verbose: true }) === "job2:v=true:r=3")
check("opts full",     runWith({ tag: "job3", verbose: false, maxRetries: 5 }) === "job3:v=false:r=5")

// ============================================================================
// 14. GENERICS — EDGE CASES
// ============================================================================
print("\n══ 14. Generics ══")

function identity<T>(v: T): T { return v }
check("generic id int",  identity<int>(42) === 42)
check("generic id str",  identity<str>("hi") === "hi")
check("generic id bool", identity<bool>(true) === true)

// Generic with multiple params
function swap<A, B>(a: A, b: B): B { return b }
check("generic swap", swap<int, str>(1, "x") === "x")

// Generic class
class Box<T> {
    value: T
    constructor(v: T) { this.value = v }
    get(): T { return this.value }
    map<U>(f: (T) => U): Box<U> { return new Box<U>(f(this.value)) }
}

const intBox = new Box<int>(10)
check("generic box get",  intBox.get() === 10)
const strBox = intBox.map((n) => `value=${n}`)
check("generic box map",  strBox.get() === "value=10")

// Generic Stack
class Stack<T> {
    private items: T[]
    constructor() { this.items = [] }
    push(item: T): void { this.items.push(item) }
    pop(): T? {
        if (this.items.length === 0) return null
        return this.items.pop()
    }
    peek(): T? {
        if (this.items.length === 0) return null
        return this.items[this.items.length - 1]
    }
    get size(): int { return this.items.length }
    get isEmpty(): bool { return this.items.length === 0 }
}

const stk = new Stack<int>()
check("stack empty init", stk.isEmpty)
stk.push(1)
stk.push(2)
stk.push(3)
check("stack size",     stk.size === 3)
check("stack peek",     stk.peek() === 3)
check("stack pop",      stk.pop() === 3)
check("stack size dec", stk.size === 2)

// ============================================================================
// 15. UNION TYPES & TYPE NARROWING
// ============================================================================
print("\n══ 15. Union types ══")

type StringOrInt = str | int
type MaybeStr = str | null

function processValue(v: StringOrInt): str {
    if (v instanceof str) {
        return "string: " + v
    } else {
        return "number: " + v
    }
}
check("union str branch",  processValue("hello") === "string: hello")
check("union int branch",  processValue(42) === "number: 42")

function orNull(v: MaybeStr): int {
    if (v === null) return 0
    return v.length
}
check("union null branch",  orNull(null) === 0)
check("union str branch 2", orNull("hi") === 2)

// Union of classes
class Square2 {
    side: float
    constructor(s: float) { this.side = s }
    area(): float { return this.side * this.side }
}

class Circle2 {
    radius: float
    constructor(r: float) { this.radius = r }
    area(): float { return 3.14 * this.radius * this.radius }
}

type Shape2 = Square2 | Circle2

function totalArea(shapes: Shape2[]): float {
    let total = 0.0
    for (const s of shapes) {
        total = total + s.area()
    }
    return total
}

const shapes: Shape2[] = [new Square2(2.0), new Circle2(1.0), new Square2(3.0)]
const ta = totalArea(shapes)
check("union class area", ta > 16.0 && ta < 20.0)

// ============================================================================
// 16. ENUMS
// ============================================================================
print("\n══ 16. Enums ══")

enum Direction { North, South, East, West }
enum HttpMethod { GET = 0, POST = 1, PUT = 2, DELETE = 3 }

const dir: Direction = Direction.North
check("enum value",       dir === Direction.North)
check("enum neq",         Direction.North !== Direction.South)
check("enum explicit",    HttpMethod.POST === 1)
check("enum rawValue",    Direction.East.rawValue === 2)

function describeDir(d: Direction): str {
    return match (d) {
        Direction.North => "going north",
        Direction.South => "going south",
        Direction.East  => "going east",
        Direction.West  => "going west"
    }
}
check("enum match N", describeDir(Direction.North) === "going north")
check("enum match W", describeDir(Direction.West) === "going west")

// ============================================================================
// 17. MAP & SET
// ============================================================================
print("\n══ 17. Map & Set ══")

const map = new Map<int>()
map.set("a", 1)
map.set("b", 2)
map.set("c", 3)
check("map size",       map.size === 3)
check("map get",        map.get("b") === 2)
check("map has",        map.has("c"))
check("map has false",  !map.has("z"))
map.delete("b")
check("map after del",  map.size === 2)
check("map get null",   map.get("b") === null)
const mk = map.keys()
check("map keys len",   mk.length === 2)
const mv = map.values()
check("map values len", mv.length === 2)
map.clear()
check("map clear",      map.size === 0)

const set = new Set<str>()
set.add("x")
set.add("y")
set.add("x")   // duplicate — should not grow
check("set size dedup",   set.size === 2)
check("set has",          set.has("x"))
check("set has false",    !set.has("z"))
set.delete("x")
check("set after delete", set.size === 1)
set.clear()
check("set clear",        set.size === 0)

// ============================================================================
// 18. RANGES
// ============================================================================
print("\n══ 18. Ranges ══")

const r1 = 0..5
const r2 = 1..=5

check("range start",          r1.start === 0)
check("range end excl",       r1.end === 5)
check("range length excl",    r1.length === 5)
check("range incl length",    r2.length === 5)
check("range contains true",  r1.contains(3))
check("range contains false", !r1.contains(5))   // exclusive
check("range incl contains",  r2.contains(5))    // inclusive

const arr2 = (0..4).toArray()
check("toArray len",   arr2.length === 4)
check("toArray first", arr2[0] === 0)
check("toArray last",  arr2[3] === 3)

const stepped = (0..10).step(3)
check("step len",   stepped.length === 4)   // 0,3,6,9
check("step value", stepped[1] === 3)

let rangeSum = 0
for (const i of 1..=10) {
    rangeSum = rangeSum + i
}
check("range for-of sum", rangeSum === 55)

const r3 = Range.from(5, 10)
check("Range.from start", r3.start === 5)
check("Range.from end",   r3.end === 10)

// ============================================================================
// 19. PIPELINE OPERATOR
// ============================================================================
print("\n══ 19. Pipeline operator ══")

function double2(n: int): int { return n * 2 }
function addN(n: int, x: int): int { return n + x }
function clamp2(lo: int, hi: int, v: int): int {
    if (v < lo) return lo
    if (v > hi) return hi
    return v
}

check("pipe simple",      5 |> double2 === 10)
check("pipe placeholder", 7 |> addN(_, 3) === 10)
check("pipe multi _",     4 |> addN(_, _) === 8)
check("pipe clamp lo",    -5 |> clamp2(0, 10, _) === 0)
check("pipe clamp hi",    15 |> clamp2(0, 10, _) === 10)
const piped = (3 |> double2) |> double2
check("pipe chained",     piped === 12)

// ============================================================================
// 20. GENERATORS
// ============================================================================
print("\n══ 20. Generators ══")

function* range_gen(start: int, end: int) {
    let i = start
    while (i < end) {
        yield i
        i = i + 1
    }
}

const gen = range_gen(0, 5)
const g0 = gen.next()
check("gen value 0",  g0.value === 0)
check("gen done 0",   !g0.done)
gen.next()
gen.next()
const g3 = gen.next()
check("gen value 3",  g3.value === 3)
const g4 = gen.next()
check("gen last",     g4.value === 4)
const gend = gen.next()
check("gen done",     gend.done)

// Fibonacci generator
function* fib_gen() {
    let a = 0
    let b = 1
    while (true) {
        yield a
        const tmp = a + b
        a = b
        b = tmp
    }
}

const fib2 = fib_gen()
const fibs: int[] = []
for (let i = 0; i < 8; i = i + 1) {
    fibs.push(fib2.next().value)
}
check("fib gen [0]", fibs[0] === 0)
check("fib gen [1]", fibs[1] === 1)
check("fib gen [7]", fibs[7] === 13)

// ============================================================================
// 21. ASYNC / AWAIT
// ============================================================================
print("\n══ 21. Async / await ══")

async function asyncAdd(a: int, b: int): int {
    return a + b
}

async function asyncChain(): str {
    const x = await asyncAdd(3, 4)
    const y = await asyncAdd(x, 10)
    return `result=${y}`
}

async function asyncError(): str {
    try {
        throw new Error("async fail")
    } catch (e) {
        return "caught:" + e.message
    }
}

async function runAsync(): void {
    const r1 = await asyncAdd(5, 6)
    check("async add", r1 === 11)

    const r2 = await asyncChain()
    check("async chain", r2 === "result=17")

    const r3 = await asyncError()
    check("async catch", r3 === "caught:async fail")
}

runAsync()

// ============================================================================
// 22. RECURSION EDGE CASES
// ============================================================================
print("\n══ 22. Recursion ══")

function fib(n: int): int {
    if (n <= 1) return n
    return fib(n - 1) + fib(n - 2)
}
check("fib 0",  fib(0) === 0)
check("fib 1",  fib(1) === 1)
check("fib 10", fib(10) === 55)

function power(base: int, exp: int): int {
    if (exp === 0) return 1
    return base * power(base, exp - 1)
}
check("power 2^0",  power(2, 0) === 1)
check("power 2^10", power(2, 10) === 1024)
check("power 0^5",  power(0, 5) === 0)

// Mutual recursion
function isEven2(n: int): bool {
    if (n === 0) return true
    return isOdd2(n - 1)
}
function isOdd2(n: int): bool {
    if (n === 0) return false
    return isEven2(n - 1)
}
check("mutual even 4", isEven2(4))
check("mutual odd 7",  isOdd2(7))
check("mutual even 0", isEven2(0))

// ============================================================================
// 23. COMPLEX OBJECT PATTERNS
// ============================================================================
print("\n══ 23. Complex objects ══")

// Method returning self (builder pattern)
class Builder {
    private parts: str[]
    constructor() { this.parts = [] }
    add(s: str): Builder {
        this.parts.push(s)
        return this
    }
    build(): str { return this.parts.join(" ") }
}

const result = new Builder().add("hello").add("from").add("builder").build()
check("builder pattern", result === "hello from builder")

// Nested class usage
class Node<T> {
    value: T
    next: Node<T>?
    constructor(v: T) {
        this.value = v
        this.next = null
    }
}

class LinkedList<T> {
    private head: Node<T>?
    private _size: int

    constructor() {
        this.head = null
        this._size = 0
    }

    prepend(v: T): void {
        const node = new Node<T>(v)
        node.next = this.head
        this.head = node
        this._size = this._size + 1
    }

    get size(): int { return this._size }

    toArray(): T[] {
        const arr: T[] = []
        let cur = this.head
        while (cur !== null) {
            arr.push(cur.value)
            cur = cur.next
        }
        return arr
    }
}

const list = new LinkedList<int>()
list.prepend(3)
list.prepend(2)
list.prepend(1)
check("linked list size",  list.size === 3)
const la = list.toArray()
check("linked list [0]",   la[0] === 1)
check("linked list [2]",   la[2] === 3)

