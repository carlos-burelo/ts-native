import { Server, Request, ServerResponse, Method, HTTP } from 'std:http'

print("█ std:http basic check")

const s = new Server()
print("Server created: " + (s !== null).toString())
print("HTTP.get exists: " + (HTTP.get !== null).toString())
print("Method.GET: " + Method.GET)
print("Method.POST: " + Method.POST)

s.get('/ping', (req: Request, res: ServerResponse) => {
    res.json({ pong: true })
})

print("Route registered")
print("  ✓ std:http API check passed")
