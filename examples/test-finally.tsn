let finallyCount = 0

function withReturn(succeed: bool): str {
    try {
        if (!succeed) throw new Error("fail")
        return "ok"
    } catch (e) {
        return "caught"
    } finally {
        finallyCount = finallyCount + 1
    }
}

const r1 = withReturn(true)
print("r1 = " + r1)
print("finallyCount = " + finallyCount)

const r2 = withReturn(false)
print("r2 = " + r2)
print("finallyCount = " + finallyCount)
