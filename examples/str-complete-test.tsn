// ── str instance methods (new in this session) ──────────────────────────────
const s = "Hello World";

// charCode
const code = "A".charCode();
assert(code == 65, "charCode A");

// concat
const joined = "Hello".concat(" World");
assert(joined == "Hello World", "concat");

// substr(start, length)
const sub1 = "abcdef".substr(2, 3);
assert(sub1 == "cde", "substr(2,3)");
const sub2 = "abcdef".substr(1);
assert(sub2 == "bcdef", "substr(1) no length");

// isEmpty / isBlank
assert("".isEmpty(), "''  isEmpty");
assert(!"hi".isEmpty(), "'hi' not isEmpty");
assert("  ".isBlank(), "'  ' isBlank");
assert(!"hi".isBlank(), "'hi' not isBlank");

// isDigit / isLetter / isWhitespace
assert("3".isDigit(), "'3' isDigit");
assert(!"a".isDigit(), "'a' not isDigit");
assert("z".isLetter(), "'z' isLetter");
assert(!" ".isLetter(), "' ' not isLetter");
assert(" ".isWhitespace(), "' ' isWhitespace");
assert(!"\t".isLetter(), "tab not isLetter");

// reverse / capitalize
assert("abc".reverse() == "cba", "reverse");
assert("hello".capitalize() == "Hello", "capitalize");
assert("".capitalize() == "", "capitalize empty");

// lines / words
const lns = "a\nb\nc".lines();
assert(lns.length == 3, "lines count");
assert(lns[0] == "a", "lines[0]");
assert(lns[2] == "c", "lines[2]");

const wds = "  foo bar  baz  ".words();
assert(wds.length == 3, "words count");
assert(wds[0] == "foo", "words[0]");
assert(wds[2] == "baz", "words[2]");

// ── str static methods ────────────────────────────────────────────────────────
// str.from
const converted = str.from(42);
assert(converted == "42", "str.from int");
const fromBool = str.from(true);
assert(fromBool == "true", "str.from bool");

// str.EMPTY
assert(str.EMPTY == "", "str.EMPTY");
assert(str.EMPTY.isEmpty(), "str.EMPTY isEmpty");

// str.fromCharCode
const ch = str.fromCharCode(65, 66, 67);
assert(ch == "ABC", "str.fromCharCode");

// str.join
const parts = ["foo", "bar", "baz"];
const joined2 = str.join(parts, ", ");
assert(joined2 == "foo, bar, baz", "str.join with sep");
const joined3 = str.join(parts);
assert(joined3 == "foobarbaz", "str.join no sep");

print("All str static + instance tests pass!");
