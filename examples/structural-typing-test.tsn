/**
 * Structural Typing Test
 */

interface Named {
    name: str
}

interface Aged {
    age: int
}

// Object literal to interface
const named: Named = {
    name: "John"
}

const aged: Aged = {
    age: 30
}

// Property access on interface
const n1: str = named.name
const a1: int = aged.age

// Object with extra properties can be assigned
const person: Named = {
    name: "Jane",
    age: 25  // Extra property is OK
}

// Test that property access works
const n2: str = person.name
