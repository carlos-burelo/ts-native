// primitive-methods-test.tsn — verifies int, float, bool instance + static methods

// ── int instance methods ─────────────────────────────────────────────────────
const n = -42;
print(`abs:       ${n.abs()}`);        // 42
print(`sign:      ${n.sign()}`);       // -1
print(`negate:    ${n.negate()}`);     // 42
print(`toFloat:   ${n.toFloat()}`);    // -42
print(`toHex:     ${10.toHex()}`);     // a
print(`toBinary:  ${5.toBinary()}`);   // 101
print(`toOctal:   ${8.toOctal()}`);    // 10
print(`min:       ${3.min(7)}`);       // 3
print(`max:       ${3.max(7)}`);       // 7
print(`clamp:     ${15.clamp(0, 10)}`); // 10
print(`toString:  ${42.toString()}`);  // 42

// ── int static methods ───────────────────────────────────────────────────────
print(`int.parse:     ${int.parse("123")}`);       // 123
print(`int.parse hex: ${int.parse("ff", 16)}`);    // 255
print(`int.min:       ${int.min(3, 1, 4, 1, 5)}`); // 1
print(`int.max:       ${int.max(3, 1, 4, 1, 5)}`); // 5
print(`int.ZERO:      ${int.ZERO}`);               // 0
print(`int.ONE:       ${int.ONE}`);                // 1
print(`int.MAX_VALUE: ${int.MAX_VALUE > 0}`);      // true

// ── float instance methods ───────────────────────────────────────────────────
const f = -3.7;
print(`float abs:   ${f.abs()}`);          // 3.7
print(`float floor: ${f.floor()}`);        // -4
print(`float ceil:  ${f.ceil()}`);         // -3
print(`float round: ${f.round()}`);        // -4
print(`float trunc: ${f.trunc()}`);        // -3
print(`float sign:  ${f.sign()}`);         // -1
print(`sqrt:        ${16.0.sqrt()}`);      // 4
print(`sin(0):      ${0.0.sin()}`);        // 0
print(`cos(0):      ${0.0.cos()}`);        // 1
print(`isNaN:       ${0.0.isNaN()}`);      // false
print(`isFinite:    ${1.0.isFinite()}`);   // true
print(`toInt:       ${3.9.toInt()}`);      // 3
print(`toFixed:     ${3.14159.toFixed(2)}`); // 3.14

// ── float static methods ─────────────────────────────────────────────────────
print(`float.parse:    ${float.parse("3.14")}`);   // 3.14
print(`float.PI:       ${float.PI > 3.14}`);       // true
print(`float.E:        ${float.E > 2.71}`);        // true
print(`float.INFINITY: ${float.INFINITY > 0}`);    // true
print(`float.min:      ${float.min(1.0, 2.0, 0.5)}`); // 0.5
print(`float.max:      ${float.max(1.0, 2.0, 0.5)}`); // 2

// ── bool instance methods ────────────────────────────────────────────────────
const t = true;
const ff = false;
print(`and:   ${t.and(ff)}`);    // false
print(`or:    ${t.or(ff)}`);     // true
print(`not:   ${t.not()}`);      // false
print(`xor:   ${t.xor(ff)}`);    // true
print(`toInt: ${t.toInt()}`);    // 1
print(`toInt: ${ff.toInt()}`);   // 0

// ── bool static methods ──────────────────────────────────────────────────────
print(`bool.parse true:  ${bool.parse("true")}`);  // true
print(`bool.parse false: ${bool.parse("false")}`); // false
print(`bool.TRUE:        ${bool.TRUE}`);            // true
print(`bool.FALSE:       ${bool.FALSE}`);           // false

print("ALL DONE");
