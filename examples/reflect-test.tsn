import { Reflect } from "std:reflect";

print("=== Reflect API Test ===\n");

// ── defineMetadata / getMetadata ─────────────────────────────────────────────
print("--- defineMetadata / getMetadata ---");

Reflect.defineMetadata("type", "User", "UserClass");
Reflect.defineMetadata("version", 2, "UserClass");
Reflect.defineMetadata("deprecated", true, "UserClass");

let typ = Reflect.getMetadata("type", "UserClass");
print("type:       " + typ);          // User

let ver = Reflect.getMetadata("version", "UserClass");
print(`version:    ${ver}`);          // 2

let dep = Reflect.getMetadata("deprecated", "UserClass");
print(`deprecated: ${dep}`);          // true

let missing = Reflect.getMetadata("nonexistent", "UserClass");
print(`missing:    ${missing}`);      // null

// ── hasMetadata ──────────────────────────────────────────────────────────────
print("\n--- hasMetadata ---");
print(`has type:       ${Reflect.hasMetadata("type",        "UserClass")}`); // true
print(`has version:    ${Reflect.hasMetadata("version",     "UserClass")}`); // true
print(`has missing:    ${Reflect.hasMetadata("nonexistent", "UserClass")}`); // false
print(`has dynamic tgt:${Reflect.hasMetadata("type",        "Unknown")}`);   // false

// ── getMetadataKeys ──────────────────────────────────────────────────────────
print("\n--- getMetadataKeys ---");
let keys = Reflect.getMetadataKeys("UserClass");
print(`key count: ${keys.length}`);   // 3 (order is unspecified)

// Verify all expected keys are present 
var hasType    = false;
var hasVersion = false;
var hasDep     = false;
for (const k of keys) {
    if (k == "type")       { hasType    = true; }
    if (k == "version")    { hasVersion = true; }
    if (k == "deprecated") { hasDep     = true; }
}
print(`keys contain 'type':       ${hasType}`);    // true
print(`keys contain 'version':    ${hasVersion}`); // true
print(`keys contain 'deprecated': ${hasDep}`);     // true

let emptyKeys = Reflect.getMetadataKeys("NoSuchTarget");
print(`keys for dynamic target: ${emptyKeys.length}`); // 0

// ── Multiple targets are isolated ────────────────────────────────────────────
print("\n--- target isolation ---");
Reflect.defineMetadata("role", "admin", "SessionClass");
print(`UserClass role:    ${Reflect.getMetadata("role", "UserClass")}`);   // null
print(`SessionClass role: ${Reflect.getMetadata("role", "SessionClass")}`); // admin
print(`UserClass key count stays 3: ${Reflect.getMetadataKeys("UserClass").length == 3}`);

// ── Overwrite an existing key ────────────────────────────────────────────────
print("\n--- overwrite ---");
Reflect.defineMetadata("type", "AdminUser", "UserClass");
print("type after overwrite: " + Reflect.getMetadata("type", "UserClass")); // AdminUser

print("\n=== All tests passed ===");
