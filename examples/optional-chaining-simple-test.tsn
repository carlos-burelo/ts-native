// Simple test for ?. operator

interface User {
    name: str
    age: int
}

const user1: User? = { name: "Alice", age: 30 }
const user2: User? = null

// Test 1: Optional chaining with non-null value
const name1: str? = user1?.name
print("Test 1 - user1?.name:")
print(name1)

// Test 2: Optional chaining with null value
const name2: str? = user2?.name
print("Test 2 - user2?.name:")
if (name2 == null) {
    print("null (correct!)")
} else {
    print(name2)
}

print("Optional chaining tests completed!")
