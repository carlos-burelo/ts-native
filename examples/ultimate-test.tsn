// SECTION 9: GENERICS (Tests binder with type parameters)
// ══════════════════════════════════════════════════════════════
print("\n█ SECTION 9: GENERICS")

function identity<T>(value: T): T {
    return value
}

function first<T>(a: T, b: T): T {
    return a
}

function second<T>(a: T, b: T): T {
    return b
}

const numId: int = identity<int>(42)
const strId: str = identity<str>("test")
const boolId: bool = identity<bool>(true)

test("generic identity<int>", numId === 42)
test("generic identity<str>", strId === "test")
test("generic identity<bool>", boolId === true)
test("generic first", first<int>(10, 20) === 10)
test("generic second", second<int>(10, 20) === 20)

// Generic classes
class Box<T> {
    value: T

    constructor(value: T) {
        this.value = value
    }

    getValue(): T {
        return this.value
    }

    setValue(v: T): void {
        this.value = v
    }
}

const intBox: Box<int> = new Box<int>(100)
const strBox: Box<str> = new Box<str>("boxed")

test("generic class Box<int>", intBox.getValue() === 100)
test("generic class Box<str>", strBox.getValue() === "boxed")
intBox.setValue(200)
test("generic class setValue", intBox.getValue() === 200)

// Multiple type parameters
function pair<A, B>(first: A, second: B): A {
    return first
}

const p1: str = pair<str, int>("key", 100)
const p2: int = pair<int, str>(200, "value")

test("generic pair<A,B> - first", p1 === "key")
test("generic pair<A,B> - second", p2 === 200)

class Pair<A, B> {
    first: A
    second: B

    constructor(first: A, second: B) {
        this.first = first
        this.second = second
    }

    getFirst(): A {
        return this.first
    }

    getSecond(): B {
        return this.second
    }
}

const pair1: Pair<str, int> = new Pair<str, int>("age", 25)
test("generic Pair<A,B>.first", pair1.getFirst() === "age")
test("generic Pair<A,B>.second", pair1.getSecond() === 25)

