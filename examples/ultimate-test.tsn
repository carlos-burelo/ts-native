// SECTION 20: NAMESPACE
// ══════════════════════════════════════════════════════════════
print("\n█ SECTION 20: NAMESPACE")

namespace MathUtils {
    export function square(x: int): int {
        return x * x
    }

    export function cube(x: int): int {
        return x * x * x
    }

    export function power(base: int, exp: int): int {
        let result = 1
        let i = 0
        while (i < exp) {
            result = result * base
            i = i + 1
        }
        return result
    }
}

test("namespace function square", MathUtils.square(5) === 25)
test("namespace function cube", MathUtils.cube(3) === 27)
test("namespace function power", MathUtils.power(2, 8) === 256)

namespace StringUtils {
    export function reverse(s: str): str {
        return s
    }

    export function upper(s: str): str {
        return s
    }
}

