// SECTION 6: CLASSES (Tests isExcludedAstProp in binder)
// ══════════════════════════════════════════════════════════════
print("\n█ SECTION 6: CLASSES")

class Counter {
    value: int

    constructor(start: int) {
        this.value = start
    }

    increment(): void {
        this.value = this.value + 1
    }

    decrement(): void {
        this.value = this.value - 1
    }

    getValue(): int {
        return this.value
    }

    setValue(v: int): void {
        this.value = v
    }
}

const counter = new Counter(10)
test("class constructor", counter.getValue() === 10)
counter.increment()
test("class method increment", counter.getValue() === 11)
counter.increment()
counter.increment()
test("class multiple increments", counter.getValue() === 13)
counter.decrement()
test("class method decrement", counter.getValue() === 12)
counter.setValue(100)


