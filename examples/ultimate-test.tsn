        return this.name
    }
}

class Dog {
    name: str
    breed: str

    constructor(name: str, breed: str) {
        this.name = name
        this.breed = breed
    }

    getName(): str {
        return this.name
    }

    getBreed(): str {
        return this.breed
    }
}

const dog = new Dog("Buddy", "Golden Retriever")
test("inheritance - getName", dog.getName() === "Buddy")
test("inheritance - getBreed", dog.getBreed() === "Golden Retriever")

// ══════════════════════════════════════════════════════════════
// SECTION 8: CLASS IMPLEMENTS INTERFACE
// ══════════════════════════════════════════════════════════════
print("\n█ SECTION 8: CLASS IMPLEMENTS INTERFACE")

interface Drawable {
    draw(): str
}

interface Resizable {
    resize(factor: int): void
}

class Circle implements Drawable {
    radius: int

    constructor(r: int) {
        this.radius = r
    }

    draw(): str {
        return "Circle"
    }

    getRadius(): int {
        return this.radius
    }
}

new Circle(5).getRadius()

class Rectangle implements Drawable, Resizable {
    width: int
    height: int

    constructor(w: int, h: int) {
        this.width = w
        this.height = h
    }

    draw(): str {
        return "Rectangle"
    }

    resize(factor: int): void {
        this.width = this.width * factor
        this.height = this.height * factor
    }

    getArea(): int {
        return this.width * this.height
    }
}

const circle = new Circle(5)
const rect = new Rectangle(4, 6)

const circle2 = new Circle(radius: 3)

test("implements Drawable - Circle", circle.draw() === "Circle")
test("implements Drawable - Rectangle", rect.draw() === "Rectangle")
test("implements Resizable - before", rect.getArea() === 24)
rect.resize(2)
test("implements Resizable - after", rect.getArea() === 96)

