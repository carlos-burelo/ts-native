// SECTION 22: METHOD CHAINING
// ══════════════════════════════════════════════════════════════
print("\n█ SECTION 22: METHOD CHAINING")

class Calculator2 {
    value: int

    constructor(start: int) {
        this.value = start
    }

    add(x: int): Calculator2 {
        this.value = this.value + x
        return this
    }

    multiply(x: int): Calculator2 {
        this.value = this.value * x
        return this
    }

    result(): int {
        return this.value
    }
}

const calc2 = new Calculator2(5)
const chainResult = calc2.add(3).multiply(2).result()
test("method chaining", chainResult === 16)

