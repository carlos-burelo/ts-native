// SECTION 14: CONTROL FLOW - IF/ELSE (Tests statement-checker)
// ══════════════════════════════════════════════════════════════
print("\n█ SECTION 14: CONTROL FLOW - IF/ELSE")

function getGrade(score: int): str {
    if (score >= 90) {
        return "A"
    } else if (score >= 80) {
        return "B"
    } else if (score >= 70) {
        return "C"
    } else if (score >= 60) {
        return "D"
    } else {
        return "F"
    }
}

test("if-else grade A", getGrade(95) === "A")
test("if-else grade B", getGrade(85) === "B")
test("if-else grade C", getGrade(75) === "C")
test("if-else grade D", getGrade(65) === "D")
test("if-else grade F", getGrade(50) === "F")



// Nested if-else
function classify(x: int): str {
    if (x > 0) {
        if (x > 100) {
            return "large positive"
        } else {
            return "small positive"
        }
    } else if (x < 0) {
        return "negative"
    } else {
        return "zero"
    }
}

test("nested if - large positive", classify(200) === "large positive")
test("nested if - small positive", classify(50) === "small positive")
test("nested if - negative", classify(-10) === "negative")
test("nested if - zero", classify(0) === "zero")

