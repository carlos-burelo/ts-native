// SECTION 23: COMPLEX GENERICS
// ══════════════════════════════════════════════════════════════
print("\n█ SECTION 23: COMPLEX GENERICS")

class Stack<T> {
    items: T[]
    top: int

    constructor() {
        this.items = []
        this.top = -1
    }

    push(item: T): void {
        this.top = this.top + 1
    }

    isEmpty(): bool {
        return this.top === -1
    }

    size(): int {
        return this.top + 1
    }
}

const intStack: Stack<int> = new Stack<int>()
test("stack isEmpty", intStack.isEmpty() === true)
intStack.push(10)
intStack.push(20)
intStack.push(30)
test("stack size", intStack.size() === 3)

// ══════════════════════════════════════════════════════════════
// SECTION 24: RECURSIVE FUNCTIONS
// ══════════════════════════════════════════════════════════════
print("\n█ SECTION 24: RECURSIVE FUNCTIONS")

function factorial(n: int): int {
    if (n <= 1) {
        return 1
    } else {
        return n * factorial(n - 1)
    }
}

function fibonacci(n: int): int {
    if (n <= 1) {
        return n
    } else {
        return fibonacci(n - 1) + fibonacci(n - 2)
    }
}

test("factorial 5", factorial(5) === 120)
test("factorial 6", factorial(6) === 720)
test("fibonacci 6", fibonacci(6) === 8)
test("fibonacci 7", fibonacci(7) === 13)

