// SECTION 17: MATCH EXPRESSIONS (Tests literal.checker)
// ══════════════════════════════════════════════════════════════
print("\n█ SECTION 17: MATCH EXPRESSIONS")

function matchNumber(n: int): str {
    return match n {
        1 => "one",
        2 => "two",
        3 => "three",
        4 => "four",
        5 => "five",
        _ => "other"
    }
}

test("match expression 1", matchNumber(1) === "one")
test("match expression 2", matchNumber(2) === "two")
test("match expression 5", matchNumber(5) === "five")
test("match expression default", matchNumber(99) === "other")

// Match with int values (enum match has type issues)
function matchIntValue(n: int): str {
    return match n {
        0 => "zero",
        1 => "one",
        2 => "two",
        _ => "other"
    }
}

const statusVal: int = 1
test("match int value 1", matchIntValue(statusVal) === "one")
test("match int value 2", matchIntValue(2) === "two")

