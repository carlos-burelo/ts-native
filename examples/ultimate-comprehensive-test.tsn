// SECTION 44: CLASS METHOD VARIATIONS
// ════════════════════════════════════════════════════════════════════════════
section("SECTION 44: CLASS METHOD VARIATIONS")

class MethodVariations {
    value: int

    constructor() {
        this.value = 0
    }

    noReturn(): void {
        this.value = 10
    }

    withReturn(): int {
        return this.value * 2
    }

    multipleParams(a: int, b: int, c: int): int {
        return a + b + c
    }
}

const methodTest = new MethodVariations()
methodTest.noReturn()
test("method no return", methodTest.value === 10)
test("method with return", methodTest.withReturn() === 20)
test("method multiple params", methodTest.multipleParams(1, 2, 3) === 6)

