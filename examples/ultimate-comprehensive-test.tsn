/**
 * ╔════════════════════════════════════════════════════════════════════════════╗
 * ║                TSN ULTIMATE ABSOLUTE COMPREHENSIVE TEST SUITE              ║
 * ║                    Testing ALL Language Features                           ║
 * ╚════════════════════════════════════════════════════════════════════════════╝
 *
 * This test file covers EVERY feature of the TSN language:
 * - Primitive types (int, float, str, bool, char, void, null)
 * - Type annotations and type aliases
 * - Nullable types and null safety operators (??, ?., !)
 * - Arrays and tuples
 * - Union and intersection types
 * - Enums
 * - Interfaces and nominal typing
 * - Classes (inheritance, implements, abstract, static)
 * - Generics (functions, classes, constraints)
 * - Functions (regular, arrow, async, generator)
 * - Control flow (if/else, switch, match expressions)
 * - Loops (for, for-of, for-in, for-await, while, do-while)
 * - Range expressions (0..10, 0..=10)
 * - Operators (arithmetic, logical, bitwise, comparison, nullish coalescing)
 * - Try-catch-finally error handling
 * - Async/await and Promises
 * - Modules (import/export)
 * - Namespaces
 * - Decorators
 * - Pattern matching
 * - Object and array destructuring
 * - Spread and rest operators
 * - Optional chaining
 * - Template literals
 * - Getters and setters
 * - Method shorthand and computed properties
 * - Named arguments and default parameters
 * - Type guards (typeof, instanceof)
 * - As/type assertions
 * - Literal types
 * - Readonly and const assertions
 */

print("╔════════════════════════════════════════════════════════════════════════════╗")
print("║           TSN ULTIMATE ABSOLUTE COMPREHENSIVE TEST SUITE                   ║")
print("╚════════════════════════════════════════════════════════════════════════════╝\n")

let testsPassed = 0
let testsTotal = 0

function test(name: str, result: bool): void {
    testsTotal = testsTotal + 1
    if (result) {
        testsPassed = testsPassed + 1
        print("  ✓ " + name)
    } else {
        print("  ✗ " + name)
    }
}

function section(name: str): void {
    print("\n══════════════════════════════════════════════════════════════")
    print("█ " + name)
    print("══════════════════════════════════════════════════════════════")
}

// ════════════════════════════════════════════════════════════════════════════
// SECTION 1: PRIMITIVE TYPES
// ════════════════════════════════════════════════════════════════════════════
section("SECTION 1: PRIMITIVE TYPES")

const testInt: int = 42
const testFloat: float = 3.14159
const testStr: str = "Hello TSN"
const testBool: bool = true
const testChar: char = 'Z'

test("int type", testInt === 42)
test("float type", testFloat === 3.14159)
test("str type", testStr === "Hello TSN")
test("bool type", testBool === true)
test("char type", testChar === 'Z')

// Test int operations
const intSum = 10 + 5
const intDiff = 10 - 3
const intProd = 6 * 7
const intDiv = 20 / 4
const intMod = 17 % 5

test("int addition", intSum === 15)
test("int subtraction", intDiff === 7)
test("int multiplication", intProd === 42)
test("int division", intDiv === 5)
test("int modulo", intMod === 2)

// Test float operations
const floatSum = 1.5 + 2.5
const floatProd = 2.5 * 2.0

test("float addition", floatSum === 4.0)
test("float multiplication", floatProd === 5.0)

// ════════════════════════════════════════════════════════════════════════════
// SECTION 2: NULLABLE TYPES & NULL SAFETY
// ════════════════════════════════════════════════════════════════════════════
section("SECTION 2: NULLABLE TYPES & NULL SAFETY")

// Nullish coalescing operator (??)
const nullable1: int? = null
const nullable2: int? = 100
const safe1: int = nullable1 ?? 0
const safe2: int = nullable2 ?? 50

test("nullish coalescing with null", safe1 === 0)
test("nullish coalescing with value", safe2 === 100)

// Chaining ??
const chain1: int? = null
const chain2: int? = 200
const chainResult = chain1 ?? chain2 ?? 999
test("nullish coalescing chain", chainResult === 200)

// Zero is NOT null
const zero: int? = 0
const notNull = zero ?? 999
test("zero is not null", notNull === 0)

