// SECTION 33: HIGHER-ORDER FUNCTIONS
// ════════════════════════════════════════════════════════════════════════════
section("SECTION 33: HIGHER-ORDER FUNCTIONS")

function applyOperation(x: int, y: int, op: (a: int, b: int) => int): int {
    return op(x, y)
}

const addition = (a: int, b: int): int => a + b
const multiplication = (a: int, b: int): int => a * b

test("higher-order add", applyOperation(5, 3, addition) === 8)
test("higher-order multiply", applyOperation(5, 3, multiplication) === 15)

