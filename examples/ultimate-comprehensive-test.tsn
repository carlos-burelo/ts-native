section("SECTION 34: STATIC MEMBERS")

class MathHelper {
    static PI: int = 3

    static square(x: int): int {
        return x * x
    }

    static cube(x: int): int {
        return x * x * x
    }
}

test("static constant", MathHelper.PI === 3)
test("static method square", MathHelper.square(4) === 16)
test("static method cube", MathHelper.cube(3) === 27)

// ════════════════════════════════════════════════════════════════════════════
// SECTION 35: GETTERS AND SETTERS (PARTIAL - Setter has runtime issues)
// ════════════════════════════════════════════════════════════════════════════
section("SECTION 35: GETTERS AND SETTERS")

class Temperature {
    private celsius: int

    constructor(c: int) {
        this.celsius = c
    }

    get value(): int {
        return this.celsius
    }

    getCelsius(): int {
        return this.celsius
    }

    setCelsius(c: int): void {
        this.celsius = c
    }

    getFahrenheit(): int {
        return (this.celsius * 9) / 5 + 32
    }
}

const temp = new Temperature(0)
test("getter initial value", temp.value === 0)
temp.setCelsius(100)
test("method setter changes value", temp.getCelsius() === 100)

// ════════════════════════════════════════════════════════════════════════════
// SECTION 36: FOR-OF LOOPS
// ════════════════════════════════════════════════════════════════════════════
section("SECTION 36: FOR-OF LOOPS")

// Basic for-of loop
let forOfSum = 0
const forOfNumbers = [10, 20, 30]
for (const num of forOfNumbers) {
    forOfSum = forOfSum + num
}
test("basic for-of loop", forOfSum === 60)

// For-of with break
let breakCount = 0
const breakItems = [1, 2, 3, 4, 5]
for (const item of breakItems) {
    if (item === 3) {
        break
    }
    breakCount = breakCount + 1
}
test("for-of with break", breakCount === 2)

// For-of with continue
let continueCount = 0
const continueItems = [1, 2, 3, 4, 5]
for (const x of continueItems) {
    if (x === 3) {
        continue
    }
    continueCount = continueCount + 1
}
test("for-of with continue", continueCount === 4)

// Nested for-of
let nestedSum = 0
const matrix = [[1, 2], [3, 4]]
for (const row of matrix) {
    for (const val of row) {
        nestedSum = nestedSum + val
    }
}
test("nested for-of", nestedSum === 10)

