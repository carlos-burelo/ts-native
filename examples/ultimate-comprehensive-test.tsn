test("arithmetic -", (10 - 3) === 7)
test("arithmetic *", (6 * 7) === 42)
test("arithmetic /", (20 / 4) === 5)
test("arithmetic %", (17 % 5) === 2)

// Precedence
test("precedence 1", (2 + 3 * 4) === 14)
test("precedence 2", ((2 + 3) * 4) === 20)
test("precedence 3", (10 - 2 * 3) === 4)

// Unary operators
test("unary plus", (+5) === 5)
test("unary minus", (-5) === -5)

