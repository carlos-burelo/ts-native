// SECTION 19: COMPLEX OBJECT LITERALS
// ════════════════════════════════════════════════════════════════════════════
section("SECTION 19: OBJECT LITERALS")

interface Address {
    street: str
    city: str
    zip: int
}

interface Employee {
    name: str
    age: int
    address: Address
}

const employee: Employee = {
    name: "John",
    age: 35,
    address: {
        street: "Main St",
        city: "Boston",
        zip: 12345
    }
}

test("nested object - name", employee.name === "John")
test("nested object - age", employee.age === 35)
test("nested object - city", employee.address.city === "Boston")
test("nested object - zip", employee.address.zip === 12345)

// Multiple levels
interface Config {
    server: str
    port: int
}

interface App {
    name: str
    version: str
    config: Config
}

const app: App = {
    name: "MyApp",
    version: "1.0",
    config: {
        server: "localhost",
        port: 8080
    }
}

test("multi-level object - app name", app.name === "MyApp")
test("multi-level object - port", app.config.port === 8080)

// ════════════════════════════════════════════════════════════════════════════
// SECTION 20: METHOD CHAINING
// ════════════════════════════════════════════════════════════════════════════
section("SECTION 20: METHOD CHAINING")

class Calculator {
    value: int

    constructor(start: int) {
        this.value = start
    }

    add(x: int): Calculator {
        this.value = this.value + x
        return this
    }

    multiply(x: int): Calculator {
        this.value = this.value * x
        return this
    }

    subtract(x: int): Calculator {
        this.value = this.value - x
        return this
    }

    result(): int {
        return this.value
    }
}

const calc = new Calculator(5)
const chainResult1 = calc.add(3).multiply(2).subtract(4).result()
test("method chaining", chainResult1 === 12)

const calc2 = new Calculator(10)
const chainResult2 = calc2.multiply(3).add(10).result()
test("method chaining 2", chainResult2 === 40)

// ════════════════════════════════════════════════════════════════════════════
// SECTION 21: GENERIC DATA STRUCTURES
// ════════════════════════════════════════════════════════════════════════════
section("SECTION 21: GENERIC DATA STRUCTURES")

class Stack<T> {
    items: T[]
    top: int

    constructor() {
        this.items = []
        this.top = -1
    }

    push(item: T): void {
        this.top = this.top + 1
    }

    isEmpty(): bool {
        return this.top === -1
    }

    size(): int {
        return this.top + 1
    }
}

const intStack: Stack<int> = new Stack<int>()
test("stack isEmpty initially", intStack.isEmpty() === true)
intStack.push(10)
intStack.push(20)
intStack.push(30)
test("stack size", intStack.size() === 3)
test("stack not empty", intStack.isEmpty() === false)

// ════════════════════════════════════════════════════════════════════════════
// SECTION 22: RECURSIVE FUNCTIONS
// ════════════════════════════════════════════════════════════════════════════
section("SECTION 22: RECURSIVE FUNCTIONS")

function factorial(n: int): int {
    if (n <= 1) {
        return 1
    } else {
        return n * factorial(n - 1)
    }
}

function fibonacci(n: int): int {
    if (n <= 1) {
        return n
    } else {
        return fibonacci(n - 1) + fibonacci(n - 2)
    }
}

function sumToN(n: int): int {
    if (n <= 0) {
        return 0
    }
    return n + sumToN(n - 1)
}

test("factorial 5", factorial(5) === 120)
test("factorial 6", factorial(6) === 720)
test("factorial 1", factorial(1) === 1)
test("fibonacci 6", fibonacci(6) === 8)
test("fibonacci 7", fibonacci(7) === 13)
test("fibonacci 0", fibonacci(0) === 0)
test("sumToN 10", sumToN(10) === 55)

// ════════════════════════════════════════════════════════════════════════════
// SECTION 23: BOOLEAN LOGIC & OPERATORS
// ════════════════════════════════════════════════════════════════════════════
section("SECTION 23: BOOLEAN LOGIC")

const t = true
const f = false

test("boolean AND true", (t && t) === true)
test("boolean AND false", (t && f) === false)
test("boolean OR true", (f || t) === true)
test("boolean OR false", (f || f) === false)
test("boolean NOT true", (!t) === false)
test("boolean NOT false", (!f) === true)

// Short-circuit evaluation
let sideEffect1 = 0
function effectTrue(): bool {
    sideEffect1 = sideEffect1 + 1
    return true
}

let sideEffect2 = 0
function effectFalse(): bool {
    sideEffect2 = sideEffect2 + 1
    return false
}

const shortCircuit1 = false && effectTrue()
test("AND short-circuit", sideEffect1 === 0)

const shortCircuit2 = true || effectFalse()
test("OR short-circuit", sideEffect2 === 0)

