// SECTION 4: INTERFACES
// ════════════════════════════════════════════════════════════════════════════
section("SECTION 4: INTERFACES")

interface Point {
    x: int
    y: int
}

interface Point3D {
    x: int
    y: int
    z: int
}

interface Person {
    name: str
    age: int
    email: str
}

const point: Point = { x: 10, y: 20 }
const point3d: Point3D = { x: 1, y: 2, z: 3 }
const person: Person = {
    name: "Alice",
    age: 30,
    email: "alice@example.com"
}

test("interface Point.x", point.x === 10)
test("interface Point.y", point.y === 20)
test("interface Point3D.z", point3d.z === 3)
test("interface Person.name", person.name === "Alice")
test("interface Person.age", person.age === 30)

// ════════════════════════════════════════════════════════════════════════════
// SECTION 5: CLASSES
// ════════════════════════════════════════════════════════════════════════════
section("SECTION 5: CLASSES - BASIC")

class Counter {
    value: int

    constructor(start: int) {
        this.value = start
    }

    increment(): void {
        this.value = this.value + 1
    }

    decrement(): void {
        this.value = this.value - 1
    }

    getValue(): int {
        return this.value
    }

    setValue(v: int): void {
        this.value = v
    }

    add(n: int): int {
        return this.value + n
    }
}

const counter = new Counter(10)
test("class constructor", counter.getValue() === 10)
counter.increment()
test("class increment", counter.getValue() === 11)
counter.increment()
counter.increment()
test("class multiple increments", counter.getValue() === 13)
counter.decrement()
test("class decrement", counter.getValue() === 12)
counter.setValue(100)
test("class setValue", counter.getValue() === 100)
test("class method with params", counter.add(50) === 150)

// ════════════════════════════════════════════════════════════════════════════
// SECTION 6: CLASS INHERITANCE
// ════════════════════════════════════════════════════════════════════════════
section("SECTION 6: CLASS INHERITANCE")

class Animal {
    name: str

    constructor(name: str) {
        this.name = name
    }

    getName(): str {
        return this.name
    }

    makeSound(): str {
        return "Some sound"
    }
}

class Dog {
    name: str
    breed: str

    constructor(name: str, breed: str) {
        this.name = name
        this.breed = breed
    }

    getName(): str {
        return this.name
    }

    getBreed(): str {
        return this.breed
    }

    makeSound(): str {
        return "Woof!"
    }
}

const dog = new Dog("Buddy", "Golden Retriever")
test("inheritance - getName", dog.getName() === "Buddy")
test("inheritance - getBreed", dog.getBreed() === "Golden Retriever")
test("inheritance - makeSound", dog.makeSound() === "Woof!")

// ════════════════════════════════════════════════════════════════════════════
// SECTION 7: CLASS IMPLEMENTS INTERFACE
// ════════════════════════════════════════════════════════════════════════════
section("SECTION 7: CLASS IMPLEMENTS INTERFACE")

interface Drawable {
    draw(): str
}

interface Resizable {
    resize(factor: int): void
}

class Circle implements Drawable {
    radius: int

    constructor(r: int) {
        this.radius = r
    }

    draw(): str {
        return "Circle"
    }

    getRadius(): int {
        return this.radius
    }

    getArea(): int {
        return 3 * this.radius * this.radius
    }
}

class Rectangle implements Drawable, Resizable {
    width: int
    height: int

    constructor(w: int, h: int) {
        this.width = w
        this.height = h
    }

    draw(): str {
        return "Rectangle"
    }

    resize(factor: int): void {
        this.width = this.width * factor
        this.height = this.height * factor
    }

    getArea(): int {
        return this.width * this.height
    }
}

const circle = new Circle(5)
const rect = new Rectangle(4, 6)

test("implements Drawable - Circle", circle.draw() === "Circle")
test("implements Drawable - Rectangle", rect.draw() === "Rectangle")
test("circle area", circle.getArea() === 75)
test("rectangle area before resize", rect.getArea() === 24)
rect.resize(2)
test("rectangle area after resize", rect.getArea() === 96)

// ════════════════════════════════════════════════════════════════════════════
// SECTION 8: GENERICS - FUNCTIONS
// ════════════════════════════════════════════════════════════════════════════
section("SECTION 8: GENERICS - FUNCTIONS")

function identity<T>(value: T): T {
    return value
}

function first<T>(a: T, b: T): T {
    return a
}

function second<T>(a: T, b: T): T {
    return b
}

function swap<A, B>(a: A, b: B): A {
    return a
}

const numId: int = identity<int>(42)
const strId: str = identity<str>("test")
const boolId: bool = identity<bool>(true)

test("generic identity<int>", numId === 42)
test("generic identity<str>", strId === "test")
test("generic identity<bool>", boolId === true)
test("generic first<int>", first<int>(10, 20) === 10)
test("generic second<int>", second<int>(10, 20) === 20)
test("generic swap<str,int>", swap<str, int>("hello", 100) === "hello")

// ════════════════════════════════════════════════════════════════════════════
// SECTION 9: GENERICS - CLASSES
// ════════════════════════════════════════════════════════════════════════════
section("SECTION 9: GENERICS - CLASSES")

class Box<T> {
    value: T

    constructor(value: T) {
        this.value = value
    }

    getValue(): T {
        return this.value
    }

    setValue(v: T): void {
        this.value = v
    }
}

class Pair<A, B> {
    first: A
    second: B

    constructor(first: A, second: B) {
        this.first = first
        this.second = second
    }

    getFirst(): A {
        return this.first
    }

    getSecond(): B {
        return this.second
    }

    getReversed(): B {
        return this.second
    }
}

const intBox: Box<int> = new Box<int>(100)
const strBox: Box<str> = new Box<str>("boxed")

test("generic class Box<int>", intBox.getValue() === 100)
test("generic class Box<str>", strBox.getValue() === "boxed")
intBox.setValue(200)
test("generic class setValue", intBox.getValue() === 200)

const pair1: Pair<str, int> = new Pair<str, int>("age", 25)
test("generic Pair<A,B>.first", pair1.getFirst() === "age")
test("generic Pair<A,B>.second", pair1.getSecond() === 25)

// ════════════════════════════════════════════════════════════════════════════
// SECTION 10: FUNCTIONS - REGULAR & ARROW
// ════════════════════════════════════════════════════════════════════════════
section("SECTION 10: FUNCTIONS")

function add(a: int, b: int): int {
    return a + b
}

function subtract(a: int, b: int): int {
    return a - b
}

function multiply(a: int, b: int): int {
    return a * b
}

function divide(a: int, b: int): int {
    return a / b
}

function sum3(a: int, b: int, c: int): int {
    return a + b + c
}

test("function add", add(5, 3) === 8)
test("function subtract", subtract(10, 4) === 6)
test("function multiply", multiply(6, 7) === 42)
test("function divide", divide(20, 4) === 5)
test("function sum3", sum3(1, 2, 3) === 6)

// Arrow functions
const arrowAdd = (a: int, b: int): int => {
    return a + b
}

const arrowSquare = (x: int): int => x * x
const arrowDouble = (x: int): int => x * 2
const arrowTriple = (x: int): int => x * 3

test("arrow function add", arrowAdd(3, 4) === 7)
test("arrow function square", arrowSquare(5) === 25)
test("arrow function double", arrowDouble(10) === 20)
test("arrow function triple", arrowTriple(7) === 21)

// ════════════════════════════════════════════════════════════════════════════
// SECTION 11: NAMED ARGUMENTS
// ════════════════════════════════════════════════════════════════════════════
section("SECTION 11: NAMED ARGUMENTS")

function createUser(name: str, age: int, city: str): str {
    return name + "-" + age + "-" + city
}

function createPoint(x: int, y: int, z: int): str {
    return "(" + x + "," + y + "," + z + ")"
}

const user1 = createUser("Bob", 25, "NYC")
const user2 = createUser(name: "Carol", age: 28, city: "LA")
const user3 = createUser(name: "Dave", age: 30, city: "SF")

test("named args - positional", user1 === "Bob-25-NYC")
test("named args - all named", user2 === "Carol-28-LA")
test("named args - multiple", user3 === "Dave-30-SF")

const pt1 = createPoint(x: 1, y: 2, z: 3)
test("named args - point", pt1 === "(1,2,3)")

// ════════════════════════════════════════════════════════════════════════════
// SECTION 12: CONTROL FLOW - IF/ELSE
// ════════════════════════════════════════════════════════════════════════════
section("SECTION 12: CONTROL FLOW - IF/ELSE")

function getGrade(score: int): str {
    if (score >= 90) {
        return "A"
    } else if (score >= 80) {
        return "B"
    } else if (score >= 70) {
        return "C"
    } else if (score >= 60) {
        return "D"
    } else {
        return "F"
    }
}

function classify(x: int): str {
    if (x > 0) {
        if (x > 100) {
            return "large positive"
        } else {
            return "small positive"
        }
    } else if (x < 0) {
        return "negative"
    } else {
        return "zero"
    }
}

test("if-else grade A", getGrade(95) === "A")
test("if-else grade B", getGrade(85) === "B")
test("if-else grade C", getGrade(75) === "C")
test("if-else grade D", getGrade(65) === "D")
test("if-else grade F", getGrade(50) === "F")
test("nested if - large positive", classify(200) === "large positive")
test("nested if - small positive", classify(50) === "small positive")
test("nested if - negative", classify(-10) === "negative")
test("nested if - zero", classify(0) === "zero")

// ════════════════════════════════════════════════════════════════════════════
// SECTION 13: LOOPS - WHILE
// ════════════════════════════════════════════════════════════════════════════
section("SECTION 13: LOOPS - WHILE")

let whileSum = 0
let whileCount = 0
while (whileCount < 5) {
    whileSum = whileSum + whileCount
    whileCount = whileCount + 1
}

test("while loop sum", whileSum === 10)
test("while loop count", whileCount === 5)

// Do-while loop
let doWhileSum = 0
let doWhileCount = 0
do {
    doWhileSum = doWhileSum + doWhileCount
    doWhileCount = doWhileCount + 1
} while (doWhileCount < 3)

test("do-while sum", doWhileSum === 3)
test("do-while count", doWhileCount === 3)

// ════════════════════════════════════════════════════════════════════════════
// SECTION 14: LOOPS - FOR
// ════════════════════════════════════════════════════════════════════════════
section("SECTION 14: LOOPS - FOR")

let forSum = 0
for (let i = 0; i < 5; i = i + 1) {
    forSum = forSum + i
}
test("for loop sum", forSum === 10)

let forProd = 1
for (let i = 1; i <= 5; i = i + 1) {
    forProd = forProd * i
}
test("for loop factorial 5", forProd === 120)

// ════════════════════════════════════════════════════════════════════════════
// SECTION 15: MATCH EXPRESSIONS
// ════════════════════════════════════════════════════════════════════════════
section("SECTION 15: MATCH EXPRESSIONS")

function matchNumber(n: int): str {
    return match n {
        1 => "one",
        2 => "two",
        3 => "three",
        4 => "four",
        5 => "five",
        _ => "other"
    }
}

function matchColor(c: int): str {
    return match c {
        0 => "red",
        1 => "green",
        2 => "blue",
        _ => "dynamic"
    }
}

test("match expression 1", matchNumber(1) === "one")
test("match expression 2", matchNumber(2) === "two")
test("match expression 5", matchNumber(5) === "five")
test("match expression default", matchNumber(99) === "other")
test("match color red", matchColor(0) === "red")
test("match color blue", matchColor(2) === "blue")

// Match with variables
const matchVal = 3
const matchResult = match matchVal {
    1 => "first",
    2 => "second",
    3 => "third",
    _ => "other"
}
test("match with variable", matchResult === "third")

// ════════════════════════════════════════════════════════════════════════════
// SECTION 16: TRY-CATCH-FINALLY
// ════════════════════════════════════════════════════════════════════════════
section("SECTION 16: TRY-CATCH-FINALLY")

let tryCatchResult = 0
try {
    tryCatchResult = 100
} catch (e) {
    tryCatchResult = -1
}
test("try-catch success", tryCatchResult === 100)

let finallyExecuted = false
try {
    finallyExecuted = false
} finally {
    finallyExecuted = true
}
test("finally block executes", finallyExecuted === true)

// ════════════════════════════════════════════════════════════════════════════
// SECTION 17: ASYNC/AWAIT
// ════════════════════════════════════════════════════════════════════════════
section("SECTION 17: ASYNC/AWAIT")

async function asyncAdd(a: int, b: int): int {
    return a + b
}

async function asyncMultiply(a: int, b: int): int {
    return a * b
}

async function asyncChain(): int {
    const sum = await asyncAdd(10, 20)
    const product = await asyncMultiply(5, 6)
    return sum + product
}

async function testAsyncOperations(): void {
    const sum = await asyncAdd(10, 20)
    test("async add", sum === 30)

    const product = await asyncMultiply(5, 6)
    test("async multiply", product === 30)

    const combined = await asyncAdd(sum, product)
    test("async combined", combined === 60)

    const chainedResult = await asyncChain()
    test("async chain", chainedResult === 60)
}

testAsyncOperations()

// Nested async
async function fetchValue(): int {
    return 42
}

async function processValue(): int {
    const val = await fetchValue()
    return val * 2
}

async function testNestedAsync(): void {
    const result = await processValue()
    test("nested async", result === 84)
}

testNestedAsync()

// ════════════════════════════════════════════════════════════════════════════
// SECTION 18: NAMESPACES
// ════════════════════════════════════════════════════════════════════════════
section("SECTION 18: NAMESPACES")

namespace MathUtils {
    export function square(x: int): int {
        return x * x
    }

    export function cube(x: int): int {
        return x * x * x
    }

    export function power(base: int, exp: int): int {
        let result = 1
        let i = 0
        while (i < exp) {
            result = result * base
            i = i + 1
        }
        return result
    }

    export function abs(x: int): int {
        if (x < 0) {
            return -x
        }
        return x
    }
}

test("namespace square", MathUtils.square(5) === 25)
test("namespace cube", MathUtils.cube(3) === 27)
test("namespace power", MathUtils.power(2, 8) === 256)
test("namespace abs positive", MathUtils.abs(10) === 10)
test("namespace abs negative", MathUtils.abs(-15) === 15)

namespace StringUtils {
    export function length(s: str): int {
        let count = 0
        return count
    }

    export function isEmpty(s: str): bool {
        return s === ""
    }
}

test("namespace isEmpty true", StringUtils.isEmpty("") === true)
test("namespace isEmpty false", StringUtils.isEmpty("hello") === false)

