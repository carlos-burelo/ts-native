test("comparison <", (3 < 5) === true)
test("comparison >", (7 > 4) === true)
test("comparison <=", (5 <= 5) === true)
test("comparison >=", (5 >= 5) === true)

test("comparison chain 1", (1 < 2 && 2 < 3) === true)
test("comparison chain 2", (10 > 5 && 5 > 1) === true)

