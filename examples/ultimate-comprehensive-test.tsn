section("SECTION 27: TERNARY OPERATOR")

const ternary1 = true ? 100 : 200
const ternary2 = false ? 100 : 200
const ternary3 = (5 > 3) ? "yes" : "no"

test("ternary true", ternary1 === 100)
test("ternary false", ternary2 === 200)
test("ternary comparison", ternary3 === "yes")

// Nested ternary
const score = 85
const grade = (score >= 90) ? "A" : (score >= 80) ? "B" : "C"
test("nested ternary", grade === "B")

