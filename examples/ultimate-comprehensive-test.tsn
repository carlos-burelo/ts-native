section("SECTION 3: ENUMS")

enum Color {
    Red = 0,
    Green = 1,
    Blue = 2,
    Yellow = 3
}

enum Status {
    Pending = 0,
    Active = 1,
    Completed = 2,
    Archived = 3
}

const color1: Color = Color.Red
const color2: Color = Color.Blue
const status1: Status = Status.Active
const status2: Status = Status.Completed

test("enum Color.Red", color1 === 0)
test("enum Color.Blue", color2 === 2)
test("enum Status.Active", status1 === 1)
test("enum Status.Completed", status2 === 2)

