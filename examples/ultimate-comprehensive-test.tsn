// SECTION 42: NESTED FUNCTIONS
// ════════════════════════════════════════════════════════════════════════════
section("SECTION 42: NESTED FUNCTIONS")

function outer(x: int): int {
    function inner(y: int): int {
        return y * 2
    }
    return inner(x) + 10
}

test("nested function", outer(5) === 20)

function outerFactory(multiplier: int): (n: int) => int {
    return (n: int): int => n * multiplier
}

const double = outerFactory(2)
const triple = outerFactory(3)
test("nested function closure 1", double(5) === 10)
test("nested function closure 2", triple(5) === 15)

