// ════════════════════════════════════════════════════════════════════════════
// SECTION 31: COMPLEX CONTROL FLOW
// ════════════════════════════════════════════════════════════════════════════
section("SECTION 31: COMPLEX CONTROL FLOW")

function complexCondition(a: int, b: int, c: int): str {
    if (a > b) {
        if (b > c) {
            return "a>b>c"
        } else if (a > c) {
            return "a>c>=b"
        } else {
            return "c>=a>b"
        }
    } else {
        if (b > c) {
            if (a > c) {
                return "b>=a>c"
            } else {
                return "b>c>=a"
            }
        } else {
            return "c>=b>=a"
        }
    }
}

test("complex condition 1", complexCondition(3, 2, 1) === "a>b>c")
test("complex condition 2", complexCondition(1, 2, 3) === "c>=b>=a")
test("complex condition 3", complexCondition(2, 3, 1) === "b>=a>c")

// ════════════════════════════════════════════════════════════════════════════
// SECTION 32: MULTIPLE RETURN PATHS
// ════════════════════════════════════════════════════════════════════════════
section("SECTION 32: MULTIPLE RETURN PATHS")

function multiReturn(n: int): int {
    if (n < 0) {
        return -1
    }
    if (n === 0) {
        return 0
    }
    if (n === 1) {
        return 1
    }
    if (n < 10) {
        return 10
    }
    return 100
}

test("multi return -1", multiReturn(-5) === -1)
test("multi return 0", multiReturn(0) === 0)
test("multi return 1", multiReturn(1) === 1)
test("multi return 10", multiReturn(5) === 10)
test("multi return 100", multiReturn(50) === 100)

