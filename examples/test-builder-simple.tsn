// Test Builder class

class Builder {
    protected value: int = 0
    protected name: str = ""

    reset(): this {
        this.value = 0
        this.name = ""
        return this
    }

    setValue(v: int): this {
        this.value = v
        return this
    }

    getValue(): int {
        return this.value
    }
}

const b = new Builder()
b.setValue(42)
print("Value: " + b.getValue())
