/**
 * Tests síncronos ejecutando funciones async sin await
 * Para ver si la VM las ejecuta
 */

async function test1(): void {
    print("TEST 1: Función async simple")
}

async function test2(): int {
    print("TEST 2: Async con retorno de valor")
    return 42
}

async function test3(): void {
    print("TEST 3: Antes de await")
    const value = await test2()
    print("TEST 3: Después de await, valor = " + value.toString())
}

async function test4(): void {
    print("TEST 4: Con try/catch")
    try {
        await test1()
        print("TEST 4: Sin error")
    } catch (e: dynamic) {
        print("TEST 4: En catch")
    }
}

async function test5(): void {
    print("TEST 5: Antes del throw")
    throw Error("Error de prueba")
    print("TEST 5: Después del throw (NO debe verse)")
}

async function test6(): void {
    print("TEST 6: Intentando capturar error")
    try {
        await test5()
        print("TEST 6: NO debe llegar aquí")
    } catch (e: dynamic) {
        print("TEST 6: Error capturado correctamente")
    }
}

print("=== REPORTE DE ASYNC/AWAIT ===")
print("")

// Ejecutar funciones async desde top-level
test1()
test2()
test3()
test4()
test6()

print("")
print("=== FIN DE PROGRAMA ===")

