import { console } from "std:console";

// ═══════════════════════════════════════════════════════════════════════════════
// GENERICS — Complete Validation Suite
// Tests all 5 implementation phases + stdlib generics + utility types
// ═══════════════════════════════════════════════════════════════════════════════

let passed = 0;
let failed = 0;

function assert(label: str, cond: bool): void {
    if (cond) {
        print("[PASS]", label);
        passed = passed + 1;
    } else {
        print("[FAIL]", label);
        failed = failed + 1;
    }
}

function assertEq(label: str, a: str, b: str): void {
    assert(label, a == b);
}

print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
print("  GAP 1 — Explicit type arguments");
print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");

function identity<T>(x: T): T { return x; }
function wrap<A, B>(a: A, b: B): A { return a; }
function second<A, B>(a: A, b: B): B { return b; }

const n1: int  = identity<int>(42);
const s1: str  = identity<str>("hello");
const b1: bool = identity<bool>(true);

assert("identity<int>(42) == 42",      n1 == 42);
assert("identity<str>('hello') == 'hello'", s1 == "hello");
assert("identity<bool>(true) == true", b1 == true);

const w1: str = wrap<str, int>("key", 100);
const w2: int = wrap<int, bool>(7, false);
assert("wrap<str,int>('key',100) == 'key'", w1 == "key");
assert("wrap<int,bool>(7,false) == 7",      w2 == 7);

const sec1: int = second<str, int>("x", 99);
const sec2: str = second<int, str>(0, "z");
assert("second<str,int>('x',99) == 99", sec1 == 99);
assert("second<int,str>(0,'z') == 'z'", sec2 == "z");

print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
print("  GAP 2 — Type inference from arguments");
print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");

const inf1 = identity<int>(42);
const inf2 = identity<str>("world");
assert("identity<int> infers to 42",      inf1 == 42);
assert("identity<str> infers to 'world'", inf2 == "world");

// Inferred without explicit type args (runtime correctness)
function double<T>(x: T): T { return x; }
const dbl1 = double(100);
const dbl2 = double("abc");
assert("double(100) == 100",   dbl1 == 100);
assert("double('abc') == 'abc'", dbl2 == "abc");

print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
print("  GAP 3 — Member access on generic types");
print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");

interface Box<T> { value: T; }
interface Pair<A, B> { first: A; second: B; }
interface Triple<X, Y, Z> { x: X; y: Y; z: Z; }

function unbox<T>(b: Box<T>): T { return b.value; }
function fst<A, B>(p: Pair<A, B>): A { return p.first; }
function snd<A, B>(p: Pair<A, B>): B { return p.second; }

const ib: Box<int>  = { value: 42 };
const sb: Box<str>  = { value: "hi" };
const bb: Box<bool> = { value: true };
const pair1: Pair<int, str> = { first: 7, second: "seven" };
const tri: Triple<int, str, bool> = { x: 1, y: "one", z: true };

assert("Box<int>.value == 42",       ib.value == 42);
assert("Box<str>.value == 'hi'",     sb.value == "hi");
assert("Box<bool>.value == true",    bb.value == true);
assert("Pair<int,str>.first == 7",   pair1.first == 7);
assert("Pair<int,str>.second == 'seven'", pair1.second == "seven");
assert("Triple<int,str,bool>.x == 1",  tri.x == 1);
assert("Triple<int,str,bool>.y == 'one'", tri.y == "one");
assert("Triple<int,str,bool>.z == true", tri.z == true);

assert("unbox<int>({value:42}) == 42",    unbox<int>(ib) == 42);
assert("unbox<str>({value:'hi'}) == 'hi'", unbox<str>(sb) == "hi");
assert("fst<int,str> == 7",               fst<int, str>(pair1) == 7);
assert("snd<int,str> == 'seven'",         snd<int, str>(pair1) == "seven");

print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
print("  GAP 4 — Constraint validation (type-level)");
print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");

// Valid constraints — these must compile without error
function clampInt<T extends int>(v: T): T { return v; }
function clampStr<T extends str>(v: T): T { return v; }

const ci: int = clampInt<int>(5);
const cs: str = clampStr<str>("ok");
assert("clampInt<int>(5) == 5",   ci == 5);
assert("clampStr<str>('ok') == 'ok'", cs == "ok");

// Note: passing a violating type (clampInt<str>) would produce a compile error
// Those are tested in utility-types-errors.tsn

print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
print("  GAP 5 — Generic class inheritance");
print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");

class Container<T> {
    item: T;
    constructor(v: T) { this.item = v; }
}
class StringContainer extends Container<str> {}
class IntContainer extends Container<int> {}

const sc = new StringContainer("payload");
const ic2 = new IntContainer(99);
assert("StringContainer inherits Container<str>.item", sc.item == "payload");
assert("IntContainer inherits Container<int>.item",    ic2.item == 99);

// Multi-level generic class
class Wrapper<T> { inner: T; }
class StrWrapper extends Wrapper<str> {}
const sw = new StrWrapper();
sw.inner = "wrapped";
assert("StrWrapper.inner == 'wrapped'", sw.inner == "wrapped");

print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
print("  Stdlib generics (Array, Map)");
print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");

const arr: int[] = [10, 20, 30];
assert("arr.length == 3", arr.length == 3);
assert("arr[0] == 10",    arr[0] == 10);
arr.push(40);
assert("arr.length after push == 4", arr.length == 4);

const strArr: str[] = ["a", "b", "c"];
const joined = strArr.join("-");
assert("['a','b','c'].join('-') == 'a-b-c'", joined == "a-b-c");

print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
print("  Utility types (Partial, Required, Readonly, NonNullable)");
print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");

interface User {
    id: int;
    name: str;
    age?: int;
}

const partial: Partial<User> = {};
partial.id = 1;
partial.name = "Alice";
assert("Partial<User>.id == 1",    partial.id == 1);
assert("Partial<User>.name == 'Alice'", partial.name == "Alice");

const required: Required<User> = { id: 2, name: "Bob", age: 30 };
assert("Required<User>.id == 2",   required.id == 2);
assert("Required<User>.age == 30", required.age == 30);

const nn: NonNullable<str | null> = "notnull";
assert("NonNullable<str|null> == 'notnull'", nn == "notnull");

print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
print("  Regression — core language features");
print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");

// Closures / arrow functions
const add = (a: int, b: int): int => a + b;
assert("arrow (a,b) => a+b: 3+4 == 7", add(3, 4) == 7);

// Destructuring
const [x, y, z] = [1, 2, 3];
assert("array destructure x==1", x == 1);
assert("array destructure y==2", y == 2);

// String methods
const upper = "hello".toUpperCase();
assert("'hello'.toUpperCase() == 'HELLO'", upper == "HELLO");

const parts = "a,b,c".split(",");
assert("'a,b,c'.split(',').length == 3", parts.length == 3);

// Numeric operations
const sum = 2 + 3 * 4;
assert("2 + 3*4 == 14", sum == 14);

// Boolean logic
const logic = true && !false || false;
assert("true && !false || false == true", logic == true);

print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
print("  RESULTS");
print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
print("Passed:", passed);
print("Failed:", failed);
if (failed == 0) {
    print("✓ All tests passed");
} else {
    print("✗ Some tests FAILED");
}
