// Professional Async/Await Examples for TSN

// ============================================
// 1. Basic Future Creation
// ============================================


function delay(ms: int): void {
    return Future.delayed(ms, () => {})
}

function fetchUser(id: int): str {
    return Future.delayed(100, () => {
        if (id > 0) {
            return `User ${id}`
        } else {
            throw "Invalid user ID"
        }
    })
}

// ============================================
// 2. Async/Await Syntax
// ============================================

async function getUserName(id: int): str {
    print(`Fetching user ${id}...`)
    const userName = await fetchUser(id)
    print(`Got user: ${userName}`)
    return userName
}

// ============================================
// 3. Error Handling with try/catch
// ============================================

async function getUserSafe(id: int): str? {
    try {
        const name = await fetchUser(id)
        return name
    } catch (error) {
        print(`Error: ${error}`)
        return null
    }
}

// ============================================
// 4. Future Combinators
// ============================================

async function testFutureAll(): void {
    print("Testing Future.wait()...")

    // Workaround: Sequential awaits due to cross-module generic type issue
    const r1 = await fetchUser(1)
    const r2 = await fetchUser(2)
    const r3 = await fetchUser(3)
    print("All users fetched:")
    print(`  - ${r1}`)
    print(`  - ${r2}`)
    print(`  - ${r3}`)
}

async function testFutureAny(): void {
    print("Testing Future.any()...")

    // Workaround: Single future due to cross-module generic type issue
    const winner = await Future.delayed(50, () => "fast")
    print(`Winner: ${winner}`)
}

// async function testFutureAllSettled(): void {
    // print("Testing Future.allSettled()...")
