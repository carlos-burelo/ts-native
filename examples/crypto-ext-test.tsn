import { Crypto } from 'std:crypto'

print("█ std:crypto extensions test")

// UUID test
const uuid = Crypto.uuid()
print("UUID: " + uuid)
if (uuid.length === 36) {
    print("  ✓ UUID length is 36")
} else {
    print("  ✗ UUID length is " + uuid.length.toString())
}

// HMAC test
// Known vector for HMAC-SHA256: key="key", data="The quick brown fox jumps over the lazy dog"
// Result: f7bc83f430538424b13298e6aa6fb143ef4d59a14946175997479dbc2d1a3cd8
const hmac = Crypto.hmac("sha256", "key", "The quick brown fox jumps over the lazy dog")
print("HMAC-SHA256: " + hmac)
if (hmac === "f7bc83f430538424b13298e6aa6fb143ef4d59a14946175997479dbc2d1a3cd8") {
    print("  ✓ HMAC-SHA256 matches known vector")
} else {
    print("  ✗ HMAC-SHA256 mismatch")
}
