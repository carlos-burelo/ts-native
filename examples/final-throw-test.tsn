// Final comprehensive test

async function testThrow(): int {
	throw "Test error message"
	return 42
}

async function main(): void {
	print("=== Test: throw in async function ===")
	try {
		const result = await testThrow()
		print(`FAIL: Got result ${result}`)
	} catch (e) {
		print(`PASS: Caught error`)
	}
}

main()
