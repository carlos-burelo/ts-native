import { FS } from 'std:fs'

async function tryCapture(): void {
    const tmp = "test-capture.txt"
    const isAbs = await FS.exists(tmp)
    print("Direct read of isAbs: " + String(isAbs))
    
    function check() {
        print("Captured isAbs = " + String(isAbs))
        return isAbs === true || isAbs === false
    }
    
    check()
}

await tryCapture()
