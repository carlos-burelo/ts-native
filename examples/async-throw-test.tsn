// Minimal test for throw inside async function

async function throwTest(): int {
	print("Before throw")
	throw "Test error"
	print("After throw - should not print")
	return 42
}

async function testThrow(): void {
	print("=== Testing throw in async function ===")
	try {
		print("Before await")
		const result = await throwTest()
		print(`ERROR: Got result ${result}`)
	} catch (error) {
		print(`SUCCESS: Caught error: ${error}`)
	}
}

function main(): void {
	testThrow()
}

main()
