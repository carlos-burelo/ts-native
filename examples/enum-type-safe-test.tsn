// Test for type-safe enums

enum Color {
    Red = 0,
    Green = 1,
    Blue = 2
}

// Test 1: Valid enum usage
const c1: Color = Color.Red
print("Test 1 - Color.Red:")
print(c1)

// Test 2: Another valid enum member
const c2: Color = Color.Blue
print("Test 2 - Color.Blue:")
print(c2)

// Test 3: This should be a type error (assigning raw number to enum)
// const c3: Color = 0  // ❌ Should fail type checking

// Test 4: Auto-increment enum
enum Status {
    Pending,
    Active,
    Completed
}

const s: Status = Status.Active
print("Test 3 - Status.Active:")
print(s)

print("Enum type-safe tests completed!")
