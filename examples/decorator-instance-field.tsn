// Simple instance field decorator test

function log(value, context): void {
  print("=== Decorator called ===")
  print("Value: " + value)
  print("Context kind: " + context.kind)
  print("Context name: " + context.name)
  print("Context static: " + context.static)
}

class Simple {
  @log
  field: str = "hello"
}

print("Creating instance...")
let obj = new Simple()
print("Created!")
print("Field value: " + obj.field)
