// examples/vtable-test.tsn

class Animal {
    name: str;
    constructor(name: str) {
        this.name = name;
    }

    speak(): str {
        return "Generic sound";
    }

    identify(): str {
        return "I am " + this.name;
    }
}

class Dog extends Animal {
    constructor(name: str) {
        super(name);
    }

    // Override speak - should keep the same V-Table index
    speak(): str {
        return "Woof!";
    }

    fetch(): str {
        return "Fetching ball...";
    }
}

class Cat extends Animal {
    constructor(name: str) {
        super(name);
    }

    speak(): str {
        return "Meow!";
    }
}

function testAnimal(a: Animal) {
    print(a.identify() + " says: " + a.speak());
}

print("--- V-Table Test ---");

const rex = new Dog("Rex");
const mimi = new Cat("Mimi");

testAnimal(rex);  // Should output: I am Rex says: Woof!
testAnimal(mimi); // Should output: I am Mimi says: Meow!

print("Rex fetch: " + rex.fetch());
