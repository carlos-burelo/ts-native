/**
 * Test: Named Arguments
 *
 * TSN was designed with named arguments support.
 * This test verifies if they work end-to-end.
 */

function greet(name: str, age: int, city: str): str {
    return name + " is " + age + " years old and lives in " + city;
}

// Test 1: Positional arguments (baseline)
const result1 = greet("Alice", 30, "NYC");
print(result1);

// Test 2: Named arguments
const result2 = greet(name: "Bob", age: 25, city: "LA");
print(result2);

// Test 3: Mixed positional and named arguments (if supported)
const result3 = greet("Charlie", age: 35, city: "SF");
print(result3);

print("Named arguments test complete!");
