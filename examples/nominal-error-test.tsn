// Test: This file should produce TYPE ERRORS
// Used to verify that nominal typing is working correctly

interface Point {
    x: int
    y: int
}

interface Vector {
    x: int
    y: int
}

function distance(p: Point): int {
    return p.x + p.y
}

// ❌ This should cause a TYPE ERROR
const v: Vector = { x: 1, y: 2 }
distance(v)  // Error: Vector is not assignable to Point

print("If you see this, nominal typing is NOT working!")
