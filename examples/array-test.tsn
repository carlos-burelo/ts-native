import { console } from  'std:console';

print(
    "a,b,c".words()  + 1
)


print("Hello, World!");


float.tryParse(1) 

print("Starting Test...");

try {
    // Test Array Natives
    print("Creating array..." );
    const arr: int[] = [1, 2, 3];
    print("Array created.");

    print("Checking length...");
    print(`Length is: ${arr.length}`);
    assert(arr.length === 3, "Array length is 3");

    const index =  1;
    print(`Accessing index ${index}...`);
    print(`Value at index ${index} is: ${arr[index]}`);
    print("Pushing...");
    arr.push(4);
    print("Push done.");
    assert(arr.length === 4, "Array push works");
    assert(arr[3] === 4, "Array push value correct");

    print("Popping...");
    const popped = arr.pop();
    assert(popped === 4, "Array pop works");
    assert(arr.length === 3, "Array length after pop");

    print("Array natives verified!");
    print("All tests passed!");
} catch (e) {
    print("CAUGHT ERROR: " + e);
}

