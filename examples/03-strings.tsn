export function run(): void {
    print("\n══ 3. String methods ══")

    const s = "  Hello, World!  "
    assert("trim",           s.trim() === "Hello, World!")
    assert("trimStart",      s.trimStart() === "Hello, World!  ")
    assert("trimEnd",        s.trimEnd() === "  Hello, World!")
    assert("toUpperCase",    "hello".toUpperCase() === "HELLO")
    assert("toLowerCase",    "WORLD".toLowerCase() === "world")
    assert("includes",       "typescript".includes("script"))
    assert("not includes",   !"typescript".includes("java"))
    assert("startsWith",     "hello world".startsWith("hello"))
    assert("endsWith",       "hello world".endsWith("world"))
    assert("indexOf found",  "abcabc".indexOf("c") === 2)
    assert("indexOf none",   "abcabc".indexOf("z") === -1)
    assert("slice",          "hello world".slice(6, 11) === "world")
    assert("slice neg",      "hello world".slice(-5) === "world")
    assert("replace",        "foo bar foo".replace("foo", "baz") === "baz bar foo")
    assert("replaceAll",     "foo bar foo".replaceAll("foo", "baz") === "baz bar baz")
    assert("split",          "a,b,c".split(",").length === 3)
    assert("split parts",    "a,b,c".split(",")[1] === "b")
    assert("repeat",         "ab".repeat(3) === "ababab")
    assert("padStart",       "5".padStart(3, "0") === "005")
    assert("padEnd",         "5".padEnd(3, "0") === "500")
    assert("length",         "hello".length === 5)
    assert("charAt",         "hello".charAt(1) === "e")
    assert("charCode A",     "A".charCode() === 65)
    assert("concat",         "Hello".concat(" World") === "Hello World")
    assert("substr 2 3",     "abcdef".substr(2, 3) === "cde")
    assert("substr 1",       "abcdef".substr(1) === "bcdef")
    assert("isEmpty true",   "".isEmpty())
    assert("isEmpty false",  !"hi".isEmpty())
    assert("isBlank true",   "   ".isBlank())
    assert("isBlank false",  !"hi".isBlank())
    assert("isDigit true",   "7".isDigit())
    assert("isDigit false",  !"a".isDigit())
    assert("isLetter true",  "z".isLetter())
    assert("isLetter false", !" ".isLetter())
    assert("reverse",        "abc".reverse() === "cba")
    assert("capitalize",     "hello".capitalize() === "Hello")
    assert("lines",          "a\nb\nc".lines().length === 3)
    assert("words",          "  foo bar  ".words().length === 2)
    assert("str.from int",   str.from(42) === "42")
    assert("str.from bool",  str.from(true) === "true")
    assert("str.EMPTY",      str.EMPTY === "")
    assert("str.fromCharCode", str.fromCharCode(72, 105) === "Hi")
    assert("str.join sep",   str.join(["a", "b", "c"], "-") === "a-b-c")
    assert("str.join empty", str.join([], ",") === "")
}
