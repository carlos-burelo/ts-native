import { console } from "std:console";

// Basic fixed-slot fields
class Point {
    x: int;
    y: int;
    constructor(x: int, y: int) {
        this.x = x;
        this.y = y;
    }
    sum(): int {
        return this.x + this.y;
    }
}

const p = new Point(3, 4);
print(p.x);       // 3
print(p.y);       // 4
print(p.sum());   // 7

// Field initializers
class Counter {
    count: int = 0;
    inc() {
        this.count = this.count + 1;
    }
}

const c = new Counter();
c.inc();
c.inc();
print(c.count);   // 2

// Inheritance still works
class Animal {
    name: str;
    constructor(name: str) {
        this.name = name;
    }
    greet(): str {
        return "I am " + this.name;
    }
}

class Dog extends Animal {
    breed: str;
    constructor(name: str, breed: str) {
        super(name);
        this.breed = breed;
    }
    info(): str {
        return this.greet() + " (" + this.breed + ")";
    }
}

const d = new Dog("Rex", "Labrador");
print(d.name);        // Rex
print(d.breed);       // Labrador
print(d.info());      // I am Rex (Labrador)

print("All slot tests passed!");
