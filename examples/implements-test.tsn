/**
 * Interface Implementation Test
 *
 * TSN debe soportar interfaces y la cláusula implements
 */

print("======================================================================")
print("IMPLEMENTS - Interface Implementation Test")
print("======================================================================")

// ============================================================================
// Test 1: Simple Interface Implementation
// ============================================================================

interface Printable {
    toString(): str
    print(): void
}

class Document implements Printable {
    content: str

    constructor(content: str) {
        this.content = content
    }

    toString(): str {
        return "Document: " + this.content
    }

    print(): void {
        print(this.toString())
    }
}

print("\n[1] SIMPLE INTERFACE IMPLEMENTATION")
const doc = new Document("Hello World")
doc.print()

// ============================================================================
// Test 2: Multiple Interface Implementation
// ============================================================================

interface Named {
    getName(): str
}

interface Identifiable {
    getId(): int
}

class User implements Named, Identifiable {
    name: str
    id: int

    constructor(name: str, id: int) {
        this.name = name
        this.id = id
    }

    getName(): str {
        return this.name
    }

    getId(): int {
        return this.id
    }
}

print("\n[2] MULTIPLE INTERFACE IMPLEMENTATION")
const user = new User("Alice", 42)
print(`User: ${user.getName()} (ID: ${user.getId()})`)

// ============================================================================
// Test 3: Interface with Properties
// ============================================================================

interface Point2D {
    x: int
    y: int
    distance(): int
}

class Point implements Point2D {
    x: int
    y: int

    constructor(x: int, y: int) {
        this.x = x
        this.y = y
    }

    distance(): int {
        return this.x * this.x + this.y * this.y
    }
}

print("\n[3] INTERFACE WITH PROPERTIES")
const p = new Point(3, 4)
print(`Point(${p.x}, ${p.y}) distance: ${p.distance()}`)

// ============================================================================
// Test 4: Extends + Implements
// ============================================================================

class BaseEntity {
    id: int

    constructor(id: int) {
        this.id = id
    }
}

interface Timestamped {
    getTimestamp(): int
}

class Article extends BaseEntity implements Timestamped {
    title: str
    timestamp: int

    constructor(id: int, title: str, timestamp: int) {
        super(id)
        this.title = title
        this.timestamp = timestamp
    }

    getTimestamp(): int {
        return this.timestamp
    }
}

print("\n[4] EXTENDS + IMPLEMENTS")
const article = new Article(1, "TSN Compiler", 2025)
print(`Article #${article.id}: ${article.title} (${article.getTimestamp()})`)

print("\n======================================================================")
print("ALL IMPLEMENTS TESTS PASSED!")
print("======================================================================")
