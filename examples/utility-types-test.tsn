interface User {
    id: int;
    name: str;
    age?: int;
}

// Partial should make all props optional
let p: Partial<User> = {};
p.id = 1;
print("Partial OK");

// Required should make all props required (including age)
let r: Required<User> = { id: 1, name: "Alice", age: 30 };
print("Required OK");

// Readonly should prevent assignment
let ro: Readonly<User> = { id: 1, name: "Alice" };
print("Readonly OK");
// ro.id = 2; // Descomenta esto para ver el error del checker

// NonNullable
let n: NonNullable<str | null> = "hello";
print("NonNullable OK");

print("Utility types verification successful");
