/**
 * Comprehensive Generic Error Test
 */

function pair<A, B>(first: A, second: B): A {
    return first
}

// ERROR: wrong return type - expects int but gets str
const wrong1: int = pair<str, int>("hello", 100)

// ERROR: wrong number of type arguments - expects 2 but gets 1
const wrong2 = pair<int>(10, 20)

// ERROR: wrong number of type arguments - expects 2 but gets 3
const wrong3 = pair<int, str, bool>(10, "hi")

function identity<T>(value: T): T {
    return value
}

// ERROR: Not a generic function
function add(a: int, b: int): int {
    return a + b
}

const wrong4 = add<int>(5, 10)
