class Actor {
    callback: () => void;
    
    run() {
        print("Actor.run...");
        this.callback();
    }
}

function level3(a: Actor) {
    print("Level 3...");
    a.run();
}

function level2(a: Actor) {
    print("Level 2...");
    level3(a);
}

function level1(a: Actor) {
    print("Level 1...");
    level2(a);
}

print("Starting deep stacktrace test...");
let a = new Actor();
level1(a);
