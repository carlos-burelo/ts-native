// Test ?. (optional chaining) and ! (non-null assertion)

class User {
    name: str;
    address: Address | null;
    constructor(name: str, address: Address | null) {
        this.name = name;
        this.address = address;
    }
    greet(): str { return "hello " + this.name; }
}

class Address {
    city: str;
    constructor(city: str) { this.city = city; }
    label(): str { return "city:" + this.city; }
}

// --- Optional chaining ---

const u1: User | null = new User("Alice", new Address("NYC"));
const u2: User | null = null;

// obj?.prop
print(u1?.name);           // Alice
print(u2?.name);           // null

// chained ?.
print(u1?.address?.city);  // NYC
print(u2?.address?.city);  // null

// obj with null address
const u3: User | null = new User("Bob", null);
print(u3?.address?.city);  // null

// obj?.method()
print(u1?.greet());        // hello Alice
print(u2?.greet());        // null

// chained method + prop
print(u1?.address?.label());  // city:NYC

// ?. on non-null is fine
const u4 = new User("Carol", new Address("LA"));
print(u4?.name);           // Carol

// --- Non-null assertion ! ---

const maybeUser: User | null = new User("Dave", new Address("SF"));

// ! strips null at compile-time, throws at runtime if null
const definiteUser = maybeUser!;
print(definiteUser.name);  // Dave

// !. chaining
print(maybeUser!.name);    // Dave
print(maybeUser!.address!.city);  // SF
print(maybeUser!.greet()); // hello Dave

// --- ! throws on null ---
const willFail: str | null = null;
try {
    const x = willFail!;
    print("should not reach");
} catch (e) {
    print("caught: " + e.message);  // caught: null assertion failed: value is null
}

// --- Narrowing: ?. result is T|null, if-check narrows it ---
const name: str | null = u1?.name;
if (name !== null) {
    print(name.length);   // 5 (Alice)
}

print("done");
