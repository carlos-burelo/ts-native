// Builtin globals (declaration-only).

export declare function print(...args: dynamic[]): void;
export declare function debug(...args: dynamic[]): void;
export declare function assert(label: str, cond: bool): void;
export declare function assertSummary(): void;
export declare function input(prompt?: str): str;

export declare const NaN: float;
export declare const Infinity: float;
export declare const Symbol: dynamic;
