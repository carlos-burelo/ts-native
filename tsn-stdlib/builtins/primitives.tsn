export declare class bool {
    toString(): str
}

export declare class char {
    toString(): str
    toInt(): int
    isDigit(): bool
    isLetter(): bool
    isWhitespace(): bool
    isUpper(): bool
    isLower(): bool
    toUpper(): char
    toLower(): char
}

export declare class Array<T> {
    readonly length: int
    push(item: T): void
    pop(): T | null
    shift(): T | null
    unshift(item: T): void
    join(separator?: str): str
    includes(item: T): bool
    indexOf(item: T): int
    slice(start?: int, end?: int): T[]
    at(index: int): T | null
    concat(other: T[]): T[]
    fill(value: T, start?: int, end?: int): T[]
    filter(predicate: (item: T, index: int) => bool): T[]
    find(predicate: (item: T) => bool): T | null
    findIndex(predicate: (item: T) => bool): int
    forEach(callback: (item: T, index: int) => void): void
    map<U>(callback: (item: T, index: int) => U): U[]
    reduce<U>(callback: (acc: U, item: T, index: int) => U, initial: U): U
    reverse(): T[]
    every(predicate: (item: T, index: int) => bool): bool
    some(predicate: (item: T, index: int) => bool): bool
    splice(start: int, deleteCount?: int, ...items: T[]): T[]
    flat<U>(): U[]
    flatMap<U>(callback: (item: T) => U[]): U[]
    sort(comparator?: (a: T, b: T) => int): T[]
    static isArray(value: unknown): bool
}
