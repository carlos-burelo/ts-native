// std:dispose — Resource-management interfaces for `using` declarations

/**
 * An object that can be synchronously disposed.
 * Implement this interface to be usable with `using`.
 */
export interface Disposable {
    dispose(): void
}

/**
 * An object that can be asynchronously disposed.
 * Implement this interface to be usable with `await using`.
 */
export interface AsyncDisposable {
    disposeAsync(): void
}
