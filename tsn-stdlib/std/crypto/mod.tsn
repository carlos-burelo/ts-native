export namespace Crypto {
    export function sha256(data: str): str 
    export function sha512(data: str): str 
    export function randomBytes(size: int): int[]
    export function randomHex(size: int): str 
    export function base64Encode(data: str): str 
    export function base64Decode(data: str): str 
    export function uuid(): str 
    export function hmac(algo: str, key: str, data: str): str 
}
